---
import Layout from '../layouts/Layout.astro';
import PaymentInfo from '../components/PaymentInfo.astro';
---

<Layout
  title="Rastrear reparación — Pixel Fix"
  description="Consulta el estado de tu reparación en Pixel Fix Monterrey."
  url="https://www.pixelfixmexico.com/reparaciones"
>
  <main class="min-h-screen max-w-5xl mx-auto px-4 py-12 md:py-20">

    <nav class="text-xs font-mono text-muted-strong mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-ink transition-colors">Inicio</a>
      <span>/</span>
      <span class="text-ink font-medium">Reparaciones</span>
    </nav>

    <div class="max-w-lg mx-auto">

      <!-- Encabezado -->
      <div class="mb-10 text-center">
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-accent-soft text-accent text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-4">
          Rastreo de reparación
        </span>
        <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-ink leading-[1.05] mb-3">
          ¿Cómo va mi reparación?
        </h1>
        <p class="text-base text-muted leading-relaxed">
          Ingresa el código de 4 caracteres que te enviamos por WhatsApp.
        </p>
      </div>

      <!-- Formulario de búsqueda -->
      <form id="rastreo-form" class="mb-10 flex gap-3">
        <input
          type="text"
          id="rastreo-input"
          name="id"
          maxlength="4"
          placeholder="Ej. a13b"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 rounded-xl border border-border-strong bg-white px-4 py-3 text-center text-xl font-mono font-bold uppercase tracking-widest text-ink placeholder:text-faint focus:outline-none focus:ring-2 focus:ring-ink/10"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-ink text-white text-sm font-medium rounded-xl hover:bg-ink-hover transition-colors"
        >
          Buscar
        </button>
      </form>

      <div id="rastreo-result"></div>

      <div class="mt-8">
        <PaymentInfo />
      </div>

    </div>

    <!-- Cómo funciona -->
    <div class="max-w-2xl mx-auto mt-20 pt-16 border-t border-border">
      <h2 class="text-lg font-medium text-ink mb-6 text-center">¿Cómo funciona el rastreo de tu reparación?</h2>
      <div class="grid sm:grid-cols-3 gap-8">
        <div>
          <span class="text-xs font-mono text-accent block mb-2">Paso 01</span>
          <h3 class="text-sm font-medium text-ink mb-2">Recibimos tu equipo</h3>
          <p class="text-xs text-muted leading-[1.6]">
            Al recibir tu equipo en el taller te asignamos un código de 4 caracteres y te lo compartimos por WhatsApp.
          </p>
        </div>
        <div>
          <span class="text-xs font-mono text-accent block mb-2">Paso 02</span>
          <h3 class="text-sm font-medium text-ink mb-2">Diagnóstico y reparación</h3>
          <p class="text-xs text-muted leading-[1.6]">
            Revisamos la falla, pedimos la pieza si hace falta y reparamos tu equipo en el taller.
          </p>
        </div>
        <div>
          <span class="text-xs font-mono text-accent block mb-2">Paso 03</span>
          <h3 class="text-sm font-medium text-ink mb-2">Consulta cuando quieras</h3>
          <p class="text-xs text-muted leading-[1.6]">
            Regresa a esta página con tu código y verás en tiempo real en qué paso va tu reparación, hasta que la tengas de vuelta.
          </p>
        </div>
      </div>
    </div>

  </main>
</Layout>

<script>
  type OrderStatus =
    | 'esperando_dispositivo'
    | 'dispositivo_recibido'
    | 'diagnostico'
    | 'esperando_pieza'
    | 'pieza_en_camino'
    | 'en_reparacion'
    | 'enviado'
    | 'entregado';

  interface Order {
    code: string;
    status: OrderStatus;
    customer_name?: string;
    description?: string;
    dhl_tracking_code?: string;
    updated_at: string;
  }

  const API = 'https://admin.bysmax.com/api';

  const STATUS_STEPS: { key: OrderStatus; label: string; description: string }[] = [
    { key: 'esperando_dispositivo', label: 'Esperando dispositivo',        description: 'Estamos esperando que nos hagas llegar tu equipo.' },
    { key: 'dispositivo_recibido',  label: 'Dispositivo recibido en taller', description: 'Recibimos tu equipo y ya está en nuestro taller.' },
    { key: 'diagnostico',           label: 'Diagnóstico',                  description: 'Estamos revisando tu equipo para confirmar la falla.' },
    { key: 'esperando_pieza',       label: 'Esperando pieza',              description: 'Pedimos la pieza necesaria para la reparación.' },
    { key: 'pieza_en_camino',       label: 'Pieza en camino',              description: 'La pieza va en camino hacia nuestro taller.' },
    { key: 'en_reparacion',         label: 'En reparación',                description: 'Tu equipo está siendo reparado.' },
    { key: 'enviado',               label: 'Enviado',                      description: 'Tu equipo va de regreso hacia ti.' },
    { key: 'entregado',             label: 'Entregado',                    description: '¡Tu equipo fue entregado!' },
  ];

  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

  function renderError(msg: string) {
    document.getElementById('rastreo-result')!.innerHTML = `
      <div class="rounded-xl border border-danger-soft bg-danger-soft p-4 text-center text-sm text-danger">
        ${esc(msg)}
      </div>`;
  }

  function renderOrder(order: Order) {
    const currentIdx = STATUS_STEPS.findIndex((s) => s.key === order.status);

    const stepsHtml = STATUS_STEPS.map((step, i) => {
      const done = i < currentIdx;
      const active = i === currentIdx;
      // La guía DHL sólo aplica si tu equipo se regresa por paquetería: se pega dentro del paso "Enviado".
      const dhlHtml = (step.key === 'enviado' && i <= currentIdx && order.dhl_tracking_code) ? `
        <div class="mt-2 rounded-xl border border-border bg-surface-muted p-3 flex items-center justify-between gap-3 flex-wrap">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-wider text-muted">Guía DHL</p>
            <p class="mt-0.5 font-mono text-sm font-medium text-ink">${esc(order.dhl_tracking_code)}</p>
          </div>
          <a href="https://www.dhl.com/mx-en/home/tracking.html?tracking-id=${encodeURIComponent(order.dhl_tracking_code)}&submit=1" target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 bg-ink text-white text-xs font-medium rounded-lg hover:bg-ink-hover transition-colors whitespace-nowrap">
            Rastrear en DHL
          </a>
        </div>` : '';
      return `
        <li class="flex gap-4 rounded-xl px-4 py-3 transition ${active ? 'bg-surface-muted' : ''}">
          <div class="flex flex-col items-center">
            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold ${
              done ? 'bg-success text-white' : active ? 'bg-ink text-white' : 'bg-border text-muted'
            }">${i + 1}</div>
            ${i < STATUS_STEPS.length - 1 ? `<div class="mt-1 w-0.5 flex-1 ${done ? 'bg-success' : 'bg-border'}" style="min-height:16px"></div>` : ''}
          </div>
          <div class="pb-3">
            <p class="text-sm font-semibold ${active || done ? 'text-ink' : 'text-muted'}">
              ${esc(step.label)}${active ? ' <span class="ml-2 text-xs font-normal text-muted">(estado actual)</span>' : ''}
            </p>
            ${(active || done) ? `<p class="mt-0.5 text-xs text-muted">${esc(step.description)}</p>` : ''}
            ${dhlHtml}
          </div>
        </li>`;
    }).join('');

    const updated = new Date(order.updated_at).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' });

    document.getElementById('rastreo-result')!.innerHTML = `
      <div class="rounded-2xl border border-border bg-surface p-6">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-muted">Código</p>
            <p class="mt-0.5 font-mono text-2xl font-bold text-ink">${esc(order.code.toUpperCase())}</p>
          </div>
          ${order.customer_name ? `
          <div class="text-right">
            <p class="text-xs font-semibold uppercase tracking-wider text-muted">Cliente</p>
            <p class="mt-0.5 text-sm font-medium text-ink">${esc(order.customer_name)}</p>
          </div>` : ''}
        </div>
        ${order.description ? `<p class="mb-6 rounded-lg bg-surface-muted px-4 py-2 text-sm text-muted-strong">${esc(order.description)}</p>` : ''}
        <ol class="relative space-y-1">${stepsHtml}</ol>
        <p class="mt-4 text-right text-xs text-faint">Actualizado: ${updated}</p>
      </div>`;
  }

  async function search(code: string) {
    const resultEl = document.getElementById('rastreo-result')!;
    if (!code) { resultEl.innerHTML = ''; return; }
    if (!/^[a-z0-9]{4}$/.test(code)) {
      renderError('El código debe ser de 4 caracteres alfanuméricos.');
      return;
    }
    try {
      const res = await fetch(`${API}/orders/code/${code}`);
      if (!res.ok) { renderError('No encontramos ninguna reparación con ese código.'); return; }
      renderOrder(await res.json());
    } catch {
      renderError('Error de conexión. Intenta de nuevo.');
    }
  }

  const input = document.getElementById('rastreo-input') as HTMLInputElement;
  const form = document.getElementById('rastreo-form') as HTMLFormElement;

  const initialCode = (new URLSearchParams(location.search).get('id') ?? '').trim().toLowerCase();
  if (initialCode) {
    input.value = initialCode;
    search(initialCode);
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const code = input.value.trim().toLowerCase();
    history.replaceState(null, '', code ? `/reparaciones?id=${code}` : '/reparaciones');
    search(code);
  });
</script>
