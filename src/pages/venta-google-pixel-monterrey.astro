---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import { salesCatalog, formatPrice } from "../data/catalog";
import { phoneNumber } from "../data/store";
import { localBusinessSchema, faqSchema } from "../lib/seo";

const faqs = [
	{
		question: "¿Los equipos son nuevos o reacondicionados?",
		answer:
			"No vendemos dispositivos reacondicionados. Ofrecemos exclusivamente teléfonos **Originales Usados en Excelente Estado (Estética 9)** que se entregan sin caja, y dispositivos en formato **Open Box** (toda la Serie 10) que sí incluyen su caja y accesorios originales completos.",
	},
	{
		question: "¿Qué garantía tienen los teléfonos y piezas?",
		answer:
			"Cualquier compra de piezas o teléfonos incluye únicamente **28 días de garantía** directa local. Transcurrido este periodo de 28 días desde la entrega, no se aceptan cambios ni devoluciones bajo ninguna circunstancia.",
	},
	{
		question: "¿Hacen envíos a todo México o entregas personales?",
		answer:
			"Hacemos entregas personales y envíos locales en Monterrey el mismo día. Para el resto del país, realizamos envíos asegurados express a través de DHL o FedEx.",
	},
	{
		question: "¿Dónde puedo comprar un Google Pixel en México de forma segura?",
		answer:
			"En Pixel Fix México somos la opción más confiable. Vendemos dispositivos Google Pixel originales (usados estética 9 y open box) con garantía directa de 28 días, brindándote soporte técnico calificado y postventa inmediata en Monterrey.",
	},
	{
		question:
			"¿Por qué comprar tu Google Pixel en Pixel Fix en lugar de importarlo por tu cuenta?",
		answer:
			"Al comprar con nosotros evitas trámites aduanales y cargos sorpresa. Todos nuestros equipos incluyen de regalo micas de pantalla, cubo de carga rápida (Fast Charge) y funda protectora. Además, cuentas con 28 días de garantía directa y soporte para tramitar la garantía oficial de fábrica de Google en USA si tu equipo califica.",
	},
];

const businessSchema = localBusinessSchema({
	name: "Pixel Fix México - Venta de Equipos",
	description:
		"Venta de teléfonos Google Pixel originales (usados estética 9 y open box) en Monterrey con garantía de 28 días.",
	priceRange: "$$$",
});

const questionsSchema = faqSchema(faqs);
---

<Layout
	title="Venta de Google Pixel en Monterrey | Equipos Usados y Open Box"
	description="Compra tu Google Pixel original en Monterrey. Celulares Usados Estética 9 y Open Box con garantía directa local de 28 días e importación segura."
	image="https://www.pixelfixmexico.com/og-image-ventas.jpg"
	url="https://www.pixelfixmexico.com/venta-google-pixel-monterrey/"
>
	<script type="application/ld+json" set:html={businessSchema} />
	<script type="application/ld+json" set:html={questionsSchema} />

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section
			class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center gap-12 reveal"
		>
			<div class="flex-1 flex flex-col items-start text-left">
				<h1
					class="mb-4 inline-flex items-center gap-2 px-3 py-1 bg-success-soft text-success text-xs font-mono font-medium rounded-full tracking-wide uppercase"
				>
					Venta de Google Pixel Originales en México
				</h1>
				<h1
					class="text-5xl md:text-[5rem] font-medium tracking-[-0.03em] text-ink leading-[1.05] mb-8"
				>
					Equipos Usados Estética 9 y Open Box Genuinos.
				</h1>
				<p
					class="text-lg md:text-xl text-muted mb-10 leading-[1.6] max-w-lg font-light"
				>
					Equipos originales (Open Box para Serie 10 con accesorios; Usados
					Estética 9 sin caja para series anteriores). Incluyen **Micas, Cubo
					Fast Charge y Funda de regalo**. Garantía local directa de 28 días.
				</p>
				<div class="flex flex-wrap gap-4 w-full">
					<a
						href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20consultar%20los%20modelos%20de%20Google%20Pixel%20disponibles%20para%20compra.`}
						target="_blank"
						rel="noopener noreferrer"
						data-umami-event="sales_hero_whatsapp_click"
						class="group inline-flex items-center justify-center px-8 py-4 bg-ink text-white text-sm font-medium rounded transition-transform hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Consultar stock en WhatsApp</span>
						<Icon name="ph:arrow-right" class="w-4 h-4 ml-3 opacity-70 group-hover:opacity-100 transition-opacity" />
					</a>
					<a
						href="/reparacion-google-pixel-monterrey#cotizador"
						data-umami-event="sales_hero_view_parts_click"
						class="inline-flex items-center justify-center px-8 py-4 bg-white border border-border text-ink text-sm font-medium rounded hover:bg-surface-muted transition-all hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Ver Piezas de Repuesto</span>
					</a>
				</div>
			</div>
			<div class="flex-1 w-full relative h-[400px] md:h-[500px]">
				<div
					class="absolute inset-0 bg-surface-muted border border-border rounded-xl overflow-hidden"
				>
					<img
						src="/hero-sales.jpg"
						alt="Modelos de Google Pixel en venta"
						fetchpriority="high"
						loading="eager"
						class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply"
					/>
					<div class="absolute inset-0 bg-ink opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Catálogo de Dispositivos -->
		<section
			id="catalogo"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-border reveal"
		>
			<div class="mb-12 max-w-2xl">
				<h2
					class="text-3xl md:text-4xl tracking-tight text-ink mb-4"
				>
					Equipos Disponibles.
				</h2>
				<p class="text-muted leading-[1.6] mb-4">
					Selecciona el modelo que buscas. Toda compra incluye de regalo:
					**micas de pantalla, cargador rápido (Fast Charge) y funda**. Precios
					para capacidad base de 128GB (256GB: +$900 MXN / 512GB: +$1,800 MXN).
				</p>
				<div
					class="inline-flex items-center px-3 py-1.5 bg-surface-muted border border-border rounded font-mono text-xs text-ink mb-2"
				>
					<span class="w-1.5 h-1.5 rounded-full bg-danger mr-2"></span>
					Garantía local directa de 28 días. No se aceptan devoluciones después.
				</div>
			</div>

			<!-- Selector de Series -->
			<div class="flex justify-center mb-10 w-full max-w-xs mx-auto">
				<div class="relative w-full">
					<select
						id="model-select"
						data-umami-event="sales_select_changed"
						class="w-full bg-white border border-border rounded-lg px-4 py-3 text-sm font-medium text-ink appearance-none cursor-pointer focus:outline-none focus:ring-1 focus:ring-ink focus:border-ink transition-all shadow-[0_2px_8px_rgba(0,0,0,0.02)]"
					>
						{
							salesCatalog.map((catalog, index) => (
								<option value={catalog.id} selected={index === 0}>
									{catalog.series}
								</option>
							))
						}
					</select>
					<div
						class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-muted"
					>
						<Icon name="ph:caret-down" class="h-4 w-4" />
					</div>
				</div>
			</div>

			<!-- Tab Contents -->
			<div class="relative min-h-[300px]">
				{
					salesCatalog.map((catalog, index) => (
						<div
							class={`tab-content grid grid-cols-1 md:grid-cols-2 gap-6 ${index === 0 ? "" : "hidden"}`}
							id={catalog.id}
						>
							{catalog.devices.map((device) => (
								<div class="bg-surface p-6 border border-border rounded-xl flex flex-col justify-between transition-all hover:shadow-[0_4px_12px_rgba(0,0,0,0.03)] hover:border-border-strong">
									<div>
										<div class="flex items-center justify-between gap-2 mb-4 border-b border-bg pb-3">
											<span class="text-xs font-mono font-medium text-muted bg-success-soft border border-border px-2.5 py-0.5 rounded-full">
												{device.availability}
											</span>
											<span class="text-[10px] font-mono text-border-strong">
												128 GB Base
											</span>
										</div>
										<h3 class="text-lg font-semibold text-ink leading-snug mb-4">
											{device.name}
										</h3>

										<div class="space-y-3 text-sm text-muted mb-6">
											<div class="flex justify-between border-b border-bg/50 pb-2">
												<span>Estado / Specs:</span>
												<span class="font-medium text-ink">
													{device.specs}
												</span>
											</div>
											<div class="flex justify-between border-b border-bg/50 pb-2">
												<span>Color disponible:</span>
												<span class="font-medium text-ink">
													{device.color}
												</span>
											</div>
											<div class="flex justify-between items-baseline pt-2">
												<span class="text-xs text-ink font-semibold">
													Precio Especial:
												</span>
												<span class="font-bold text-ink font-mono text-lg">
													{formatPrice(device.price, device.ganancia)}
												</span>
											</div>
										</div>
									</div>

									<a
										href="#"
										data-msg={`Hola Pixel Fix, me interesa comprar el ${device.name} (${device.specs}) que tienen en ${formatPrice(device.price, device.ganancia)}.`}
										data-umami-event="sales_comprar_click"
										data-umami-event-device={device.name}
										data-umami-event-price={formatPrice(
											device.price,
											device.ganancia,
										)}
										class="wa-link block w-full text-center py-3 bg-ink hover:bg-ink-hover text-white text-xs font-mono font-medium rounded transition-transform hover:scale-[0.98]"
									>
										Apartar / Comprar
									</a>
								</div>
							))}
						</div>
					))
				}
			</div>
		</section>

		<!-- Enlace contextual a reparaciones -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div
				class="bg-surface p-8 border border-border rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
			>
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-ink mb-2">
						¿Ya tienes un Google Pixel y necesita reparación?
					</h3>
					<p class="text-sm text-muted leading-[1.6]">
						Ofrecemos servicio técnico especializado, cambio de baterías y
						pantallas originales con piezas autorizadas de Google importadas
						desde iFixit. Conoce nuestro laboratorio de <a
							href="/reparacion-google-pixel-monterrey"
							data-umami-event="sales_contextual_repairs_link_click"
							class="text-ink underline hover:text-accent transition-colors"
							>reparación de Google Pixel en Monterrey y envíos nacionales</a
						>.
					</p>
				</div>
				<a
					href="/reparacion-google-pixel-monterrey"
					data-umami-event="sales_go_to_repairs_click"
					class="px-6 py-3.5 bg-ink text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0"
				>
					Servicio de Reparación
				</a>
			</div>
		</section>

		<ProcessSteps
			title="Proceso de Adquisición."
			description="Comprar tu Google Pixel es rápido y seguro. Entregas personales o envíos urgentes a todo México."
			steps={[
				{ title: "Preguntas por Stock", description: "Escríbenos para confirmar disponibilidad y colores del modelo Pixel que deseas." },
				{ title: "Pago y Entrega", description: "Coordinamos el pago seguro contra entrega en Monterrey, o te enviamos tu guía express asegurada nacional." },
				{ title: "Usa con Garantía", description: "Recibes tu equipo listo para activar y con nuestra póliza de garantía local directa." },
			]}
		/>

		<!-- Testimoniales (Abstraído) -->
		<Testimonials />

		<Faq
			description="Todo lo que necesitas saber antes de comprar tu Google Pixel."
			items={faqs}
		/>
	</main>
</Layout>

<script>
	import { phoneNumber as PHONE_NUMBER } from "../data/store";

	// Model Selector Logic
	const modelSelect = document.getElementById("model-select");
	const contents = document.querySelectorAll(".tab-content");

	if (modelSelect) {
		modelSelect.addEventListener("change", (e) => {
			const targetId = (e.target as HTMLSelectElement).value;
			contents.forEach((c) => c.classList.add("hidden"));
			const targetEl = document.getElementById(targetId);
			if (targetEl) targetEl.classList.remove("hidden");
		});
	}

	// WhatsApp Links Builder
	const waLinks = document.querySelectorAll(".wa-link");

	waLinks.forEach((link) => {
		const msg = link.getAttribute("data-msg");
		if (msg) {
			link.setAttribute(
				"href",
				`https://wa.me/${PHONE_NUMBER}?text=${encodeURIComponent(msg)}`,
			);
			link.setAttribute("target", "_blank");
			link.setAttribute("rel", "noopener noreferrer");
		}
	});

</script>
