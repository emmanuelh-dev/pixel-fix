---
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import { salesCatalog, formatPrice } from "../data/catalog";

const faqs = [
	{
		question: "¿Los equipos son nuevos o reacondicionados?",
		answer:
			"No vendemos dispositivos reacondicionados. Ofrecemos exclusivamente teléfonos **Originales Usados en Excelente Estado (Estética 9)** que se entregan sin caja, y dispositivos en formato **Open Box** (toda la Serie 10) que sí incluyen su caja y accesorios originales completos.",
	},
	{
		question: "¿Qué garantía tienen los teléfonos y piezas?",
		answer:
			"Cualquier compra de piezas o teléfonos incluye únicamente **28 días de garantía** directa local. Transcurrido este periodo de 28 días desde la entrega, no se aceptan cambios ni devoluciones bajo ninguna circunstancia.",
	},
	{
		question: "¿Hacen envíos a todo México o entregas personales?",
		answer:
			"Hacemos entregas personales y envíos locales en Monterrey el mismo día. Para el resto del país, realizamos envíos asegurados express a través de DHL o FedEx.",
	},
	{
		question: "¿Dónde puedo comprar un Google Pixel en México de forma segura?",
		answer:
			"En Pixel Fix México somos la opción más confiable. Vendemos dispositivos Google Pixel originales (usados estética 9 y open box) con garantía directa de 28 días, brindándote soporte técnico calificado y postventa inmediata en Monterrey.",
	},
	{
		question: "¿Por qué comprar tu Google Pixel en Pixel Fix en lugar de importarlo por tu cuenta?",
		answer:
			"Al comprar con nosotros evitas trámites aduanales y cargos sorpresa. Todos nuestros equipos incluyen de regalo micas de pantalla, cubo de carga rápida (Fast Charge) y funda protectora. Además, cuentas con 28 días de garantía directa y soporte para tramitar la garantía oficial de fábrica de Google en USA si tu equipo califica.",
	},
];

const phoneNumber = "528111913676";

const localBusinessSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	name: "Pixel Fix México - Venta de Equipos",
	image: "https://www.pixelfixmexico.com/logo.png",
	description:
		"Venta de teléfonos Google Pixel originales (usados estética 9 y open box) en Monterrey con garantía de 28 días.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Monterrey",
		addressRegion: "NL",
		addressCountry: "MX",
	},
	priceRange: "$$$",
	telephone: `+${phoneNumber}`,
});

const faqSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
});
---

<Layout
	title="Venta de Google Pixel en Monterrey | Equipos Usados y Open Box"
	description="Compra tu Google Pixel original en Monterrey. Celulares Usados Estética 9 y Open Box con garantía directa local de 28 días e importación segura."
	image="https://www.pixelfixmexico.com/og-image-ventas.jpg"
	url="https://www.pixelfixmexico.com/venta-google-pixel-monterrey/"
>
	<script type="application/ld+json" set:html={localBusinessSchema} />
	<script type="application/ld+json" set:html={faqSchema} />

	<!-- Ambient background -->
	<div class="fixed inset-0 pointer-events-none z-[-1] bg-[#F3F3F1]">
		<div
			class="absolute inset-0 opacity-[0.03] animate-[pulse_20s_ease-in-out_infinite]"
			style="background: radial-gradient(circle at 50% 0%, #111111 0%, transparent 60%);"
		>
		</div>
	</div>

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section
			class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center gap-12 reveal"
		>
			<div class="flex-1 flex flex-col items-start text-left">
				<h1
					class="mb-4 inline-flex items-center gap-2 px-3 py-1 bg-[#EDF3EC] text-[#346538] text-xs font-mono font-medium rounded-full tracking-wide uppercase"
				>
					Venta de Google Pixel Originales en México
				</h1>
				<h1
					class="font-serif-editorial text-5xl md:text-[5rem] font-medium tracking-[-0.03em] text-[#111111] leading-[1.05] mb-8"
				>
					Equipos Usados Estética 9 y Open Box Genuinos.
				</h1>
				<p
					class="text-lg md:text-xl text-[#787774] mb-10 leading-[1.6] max-w-lg font-light"
				>
					Equipos originales (Open Box para Serie 10 con accesorios; Usados Estética 9 sin caja para series anteriores). Incluyen **Micas, Cubo Fast Charge y Funda de regalo**. Garantía local directa de 28 días.
				</p>
				<a
					href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20consultar%20los%20modelos%20de%20Google%20Pixel%20disponibles%20para%20compra.`}
					target="_blank"
					rel="noopener noreferrer"
					data-umami-event="sales_hero_whatsapp_click"
					class="group inline-flex items-center justify-center px-8 py-4 bg-[#111111] text-white text-sm font-medium rounded transition-transform hover:scale-[0.98]"
				>
					<span>Consultar stock en WhatsApp</span>
					<svg
						class="w-4 h-4 ml-3 opacity-70 group-hover:opacity-100 transition-opacity"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
					</svg>
				</a>
			</div>
			<div class="flex-1 w-full relative h-[400px] md:h-[500px]">
				<div
					class="absolute inset-0 bg-[#F9F9F8] border border-[#EAEAEA] rounded-xl overflow-hidden"
				>
					<img
						src="https://picsum.photos/seed/pixelphone/800/1000"
						alt="Modelos de Google Pixel en venta"
						class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply"
					/>
					<div class="absolute inset-0 bg-[#111111] opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Catálogo de Dispositivos -->
		<section
			id="catalogo"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-12 max-w-2xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Equipos Disponibles.
				</h2>
				<p class="text-[#787774] leading-[1.6] mb-4">
					Selecciona el modelo que buscas. Toda compra incluye de regalo: **micas de pantalla, cargador rápido (Fast Charge) y funda**. Precios para capacidad base de 128GB (256GB: +$900 MXN / 512GB: +$1,800 MXN).
				</p>
				<div
					class="inline-flex items-center px-3 py-1.5 bg-[#F9F9F8] border border-[#EAEAEA] rounded font-mono text-xs text-[#111111] mb-2"
				>
					<span class="w-1.5 h-1.5 rounded-full bg-[#9F2F2D] mr-2"></span>
					Garantía local directa de 28 días. No se aceptan devoluciones después.
				</div>
			</div>

			<!-- Tabs -->
			<div class="flex flex-wrap gap-2 mb-10" id="model-tabs">
				{
					salesCatalog.map((catalog, index) => (
						<button
							class={`tab-btn px-5 py-2.5 rounded text-sm transition-all duration-200 ${index === 0 ? "bg-[#111111] text-white active-tab" : "bg-[#FFFFFF] border border-[#EAEAEA] text-[#787774] hover:bg-[#F9F9F8]"}`}
							data-target={catalog.id}
							data-umami-event="sales_tab_click"
							data-umami-event-tab={catalog.id}
						>
							{catalog.series}
						</button>
					))
				}
			</div>

			<!-- Tab Contents -->
			<div class="relative min-h-[300px]">
				{
					salesCatalog.map((catalog, index) => (
						<div
							class={`tab-content grid gap-6 ${index === 0 ? "" : "hidden"}`}
							id={catalog.id}
						>
							{catalog.devices.map((device) => (
								<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row md:items-start justify-between gap-8 transition-shadow hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]">
									<div class="flex-1">
										<div class="flex items-center gap-3 mb-4">
											<h3 class="text-xl font-medium text-[#111111]">
												{device.name}
											</h3>
											<span class="text-[10px] uppercase tracking-[0.05em] font-medium text-[#787774] bg-[#EDF3EC] border border-[#EAEAEA] px-2 py-0.5 rounded-full">
												{device.availability}
											</span>
										</div>
										<div class="space-y-4 text-sm text-[#787774]">
											<div class="flex justify-between border-b border-[#EAEAEA] pb-3">
												<span>Estado / Specs:</span>
												<span class="font-medium text-[#111111]">
													{device.specs}
												</span>
											</div>
											<div class="flex justify-between border-b border-[#EAEAEA] pb-3">
												<span>Color disponible:</span>
												<span class="font-medium text-[#111111]">
													{device.color}
												</span>
											</div>
											<div class="flex justify-between pt-1">
												<span>Precio Especial:</span>
												<span class="font-bold text-[#111111] font-mono text-base">
													{formatPrice(device.price, device.ganancia)}
												</span>
											</div>
										</div>
									</div>
									<div class="w-full md:w-64 shrink-0 flex flex-col gap-3 justify-center">
										<a
											href="#"
											data-msg={`Hola Pixel Fix, me interesa comprar el ${device.name} (${device.specs}) que tienen en ${formatPrice(device.price, device.ganancia)}.`}
											data-umami-event="sales_comprar_click"
											data-umami-event-device={device.name}
											data-umami-event-price={formatPrice(device.price, device.ganancia)}
											class="wa-link text-center px-4 py-3 bg-[#111111] text-white text-sm font-medium rounded hover:scale-[0.98] transition-transform"
										>
											Apartar / Comprar Equipo
										</a>
									</div>
								</div>
							))}
						</div>
					))
				}
			</div>
		</section>

		<!-- Enlace contextual a reparaciones -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow">
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-[#111111] mb-2">¿Ya tienes un Google Pixel y necesita reparación?</h3>
					<p class="text-sm text-[#787774] leading-[1.6]">
						Ofrecemos servicio técnico especializado, cambio de baterías y pantallas originales con piezas autorizadas de Google importadas desde iFixit. Conoce nuestro laboratorio de <a href="/reparacion-google-pixel-monterrey" data-umami-event="sales_contextual_repairs_link_click" class="text-[#111111] underline hover:text-[#1F6C9F] transition-colors">reparación de Google Pixel en Monterrey y envíos nacionales</a>.
					</p>
				</div>
				<a href="/reparacion-google-pixel-monterrey" data-umami-event="sales_go_to_repairs_click" class="px-6 py-3.5 bg-[#111111] text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0">
					Servicio de Reparación
				</a>
			</div>
		</section>

		<!-- Proceso de Compra -->
		<section
			id="proceso"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-16 max-w-xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Proceso de Adquisición.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Comprar tu Google Pixel es rápido y seguro. Entregas personales o
					envíos urgentes a todo México.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6">
				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						01
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Preguntas por Stock
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Escríbenos para confirmar disponibilidad y colores del modelo Pixel
						que deseas.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						02
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Pago y Entrega
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Coordinamos el pago seguro contra entrega en Monterrey, o te
						enviamos tu guía express asegurada nacional.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						03
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Usa con Garantía
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Recibes tu equipo listo para activar y con nuestra póliza de
						garantía local directa.
					</p>
				</div>
			</div>
		</section>

		<!-- Testimoniales (Abstraído) -->
		<Testimonials />

		<!-- Dudas Frecuentes -->
		<section
			id="faq"
			class="max-w-3xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-12">
				<h2
					class="font-serif-editorial text-3xl tracking-tight text-[#111111] mb-4"
				>
					Dudas Frecuentes.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Todo lo que necesitas saber antes de comprar tu Google Pixel.
				</p>
			</div>

			<div class="space-y-6">
				{
					faqs.map((faq) => (
						<div class="pb-6 border-b border-[#EAEAEA]">
							<h3 class="text-lg font-medium text-[#111111] mb-3">
								{faq.question}
							</h3>
							<p class="text-[#787774] text-sm leading-[1.6]">{faq.answer}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<script>
	// Tab Switching Logic
	const tabs = document.querySelectorAll(".tab-btn");
	const contents = document.querySelectorAll(".tab-content");

	tabs.forEach((tab) => {
		tab.addEventListener("click", () => {
			tabs.forEach((t) => {
				t.classList.remove("bg-[#111111]", "text-white", "active-tab");
				t.classList.add(
					"bg-[#FFFFFF]",
					"border",
					"border-[#EAEAEA]",
					"text-[#787774]",
				);
			});
			contents.forEach((c) => c.classList.add("hidden"));

			tab.classList.remove(
				"bg-[#FFFFFF]",
				"border",
				"border-[#EAEAEA]",
				"text-[#787774]",
			);
			tab.classList.add("bg-[#111111]", "text-white", "active-tab");
			const targetId = tab.getAttribute("data-target");
			const targetEl = document.getElementById(targetId);
			if (targetEl) targetEl.classList.remove("hidden");
		});
	});

	// WhatsApp Links Builder
	const PHONE_NUMBER = "528111913676";
	const waLinks = document.querySelectorAll(".wa-link");

	waLinks.forEach((link) => {
		const msg = link.getAttribute("data-msg");
		if (msg) {
			link.setAttribute(
				"href",
				`https://wa.me/${PHONE_NUMBER}?text=${encodeURIComponent(msg)}`,
			);
			link.setAttribute("target", "_blank");
			link.setAttribute("rel", "noopener noreferrer");
		}
	});

	// Scroll Reveal
	const observer = new IntersectionObserver(
		(entries, obs) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("revealed");
					obs.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1 },
	);

	document.querySelectorAll(".reveal").forEach((el) => {
		observer.observe(el);
	});
</script>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
			transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}
</style>
