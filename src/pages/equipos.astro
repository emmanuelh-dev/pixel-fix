---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import { phoneNumber, facebookUrl } from "../data/store";
import { localBusinessSchema, faqSchema, breadcrumbSchema } from "../lib/seo";
import Store from "../components/Store.astro";

const faqs = [
	{
		question: "¿Los equipos son nuevos o reacondicionados?",
		answer:
			"No vendemos dispositivos reacondicionados. Ofrecemos tres tipos de equipos: **Nuevos y Sellados** (sin abrir, con todos sus accesorios de fábrica), **Open Box** (Serie 10 con caja y accesorios originales completos) y **Usados Estética 9** (series anteriores, en excelente estado, se entregan con su caja).",
	},
	{
		question: "¿Qué garantía tienen los teléfonos y piezas?",
		answer:
			"Cualquier compra de piezas o teléfonos incluye únicamente **28 días de garantía** directa local. Transcurrido este periodo de 28 días desde la entrega, no se aceptan cambios ni devoluciones bajo ninguna circunstancia.",
	},
	{
		question: "¿Hacen envíos a todo México o entregas personales?",
		answer:
			"Hacemos entregas personales y envíos locales en Monterrey el mismo día. Para el resto del país, realizamos envíos asegurados express a través de DHL.",
	},
	{
		question: "¿Dónde puedo comprar un Google Pixel en México de forma segura?",
		answer:
			"En Pixel Fix México somos la opción más confiable. Vendemos dispositivos Google Pixel originales (usados estética 9 y open box) con garantía directa de 28 días, brindándote soporte técnico calificado y postventa inmediata en Monterrey.",
	},
	{
		question:
			"¿Por qué comprar tu Google Pixel en Pixel Fix en lugar de importarlo por tu cuenta?",
		answer:
			"Al comprar con nosotros evitas trámites aduanales y cargos sorpresa. Todos nuestros equipos incluyen de regalo micas de pantalla, cubo de carga rápida (Fast Charge) y funda protectora. Además, cuentas con 28 días de garantía directa y soporte para tramitar la garantía oficial de fábrica de Google en USA si tu equipo califica.",
	},
];

const businessSchema = localBusinessSchema({
	name: "Pixel Fix México - Venta de Equipos",
	description:
		"Venta de teléfonos Google Pixel originales (usados estética 9 y open box) en Monterrey con garantía de 28 días.",
	priceRange: "$$$",
	sameAs: [facebookUrl],
});

const questionsSchema = faqSchema(faqs);

const breadcrumbsSchema = breadcrumbSchema([
	{ name: "Inicio", url: "https://www.pixelfixmexico.com/" },
	{ name: "Venta de Equipos", url: "https://www.pixelfixmexico.com/equipos/" },
]);
---

<Layout
	title="Venta de Google Pixel en Monterrey | Equipos Usados y Open Box"
	description="Compra tu Google Pixel original en Monterrey. Celulares Usados Estética 9 y Open Box con garantía directa local de 28 días e importación segura."
	image="https://www.pixelfixmexico.com/og-image-ventas.jpg"
	url="https://www.pixelfixmexico.com/equipos/"
>
	<script type="application/ld+json" set:html={businessSchema} />
	<script type="application/ld+json" set:html={questionsSchema} />
	<script type="application/ld+json" set:html={breadcrumbsSchema} />

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section
			class="max-w-5xl mx-auto px-6 pt-12 pb-16 md:py-32 flex flex-col md:flex-row items-center gap-10 md:gap-12 reveal"
		>
			<div class="flex-1 flex flex-col items-start text-left">
				<span
					class="mb-4 inline-flex items-center gap-2 px-3 py-1 bg-success-soft text-success text-xs font-mono font-medium rounded-full tracking-wide uppercase"
				>
					Nuevos · Open Box · Usados Estética 9
				</span>
				<h1
					class="text-4xl md:text-4xl font-medium tracking-[-0.03em] text-ink leading-[1.15] mb-6"
				>
					Compra tu <span class="whitespace-nowrap">Google Pixel</span> en México.
				</h1>
				<p
					class="text-base md:text-xl text-muted mb-8 leading-[1.6] max-w-lg font-light"
				>
					Equipos originales: Nuevos y Sellados, Open Box (Serie 10, con caja y accesorios) y Usados Estética 9 (series anteriores, con su caja). Incluyen **Micas, Cubo Fast Charge y Funda de regalo**. Garantía local directa de 28 días.
				</p>
				<div class="flex flex-wrap gap-4 w-full">
					<a
						href="#equipos"
						data-umami-event="sales_hero_view_models_click"
						class="group inline-flex items-center justify-center px-8 py-4 bg-ink text-white text-sm font-medium rounded transition-transform hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Ver Modelos Disponibles</span>
						<Icon name="ph:arrow-right" class="w-4 h-4 ml-3 opacity-70 group-hover:opacity-100 transition-opacity" />
					</a>
					<a
						href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20consultar%20los%20modelos%20de%20Google%20Pixel%20disponibles%20para%20compra.`}
						target="_blank"
						rel="noopener noreferrer"
						data-umami-event="sales_hero_whatsapp_click"
						class="inline-flex items-center justify-center px-8 py-4 bg-white border border-border text-ink text-sm font-medium rounded hover:bg-surface-muted transition-all hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Consultar por WhatsApp</span>
					</a>
				</div>
			</div>
			<div class="flex-1 w-full relative h-[260px] md:h-[500px]">
				<div
					class="absolute inset-0 bg-surface-muted border border-border rounded-xl overflow-hidden"
				>
					<img
						src="/hero-sales.jpg"
						alt="Modelos de Google Pixel en venta"
						fetchpriority="high"
						loading="eager"
						class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply"
					/>
					<div class="absolute inset-0 bg-ink opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Catálogo de Equipos -->
		<section id="equipos" class="max-w-5xl mx-auto px-6 pt-24 pb-6 border-t border-border reveal">
			<div class="max-w-2xl">
				<h2 class="text-3xl md:text-4xl tracking-tight text-ink mb-4">
					Equipos Disponibles.
				</h2>
				<p class="text-muted leading-[1.6] mb-4">
					Filtra por serie o modelo. Toda compra incluye de regalo: **micas de
					pantalla, cargador rápido (Fast Charge) y funda**. Precios para
					128GB base (256GB: +$900 MXN / 512GB: +$1,800 MXN).
				</p>
				<div
					class="inline-flex items-center px-3 py-1.5 bg-surface-muted border border-border rounded font-mono text-xs text-ink mb-2"
				>
					<span class="w-1.5 h-1.5 rounded-full bg-danger mr-2"></span>
					Garantía local directa de 28 días. No se aceptan devoluciones después.
				</div>
			</div>
		</section>
		<Store categoryFilter="equipo" />

		<!-- Enlace contextual a reparaciones -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div
				class="bg-surface p-8 border border-border rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
			>
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-ink mb-2">
						¿Ya tienes un Google Pixel y necesita reparación?
					</h3>
					<p class="text-sm text-muted leading-[1.6]">
						Ofrecemos servicio técnico especializado, cambio de baterías y
						pantallas originales con piezas autorizadas de Google importadas
						desde iFixit. Conoce nuestro laboratorio de <a
							href="/reparacion-google-pixel-monterrey"
							data-umami-event="sales_contextual_repairs_link_click"
							class="text-ink underline hover:text-accent transition-colors"
							>reparación de Google Pixel en Monterrey y envíos nacionales</a
						>.
					</p>
				</div>
				<a
					href="/reparacion-google-pixel-monterrey"
					data-umami-event="sales_go_to_repairs_click"
					class="px-6 py-3.5 bg-ink text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0"
				>
					Servicio de Reparación
				</a>
			</div>
		</section>

		<ProcessSteps
			title="Proceso de Adquisición."
			description="Comprar tu Google Pixel es rápido y seguro. Entregas personales o envíos urgentes a todo México."
			steps={[
				{ title: "Preguntas por Stock", description: "Escríbenos para confirmar disponibilidad y colores del modelo Pixel que deseas." },
				{ title: "Pago y Entrega", description: "Coordinamos el pago seguro contra entrega en Monterrey, o te enviamos tu guía express asegurada nacional." },
				{ title: "Usa con Garantía", description: "Recibes tu equipo listo para activar y con nuestra póliza de garantía local directa." },
			]}
		/>

		<!-- Testimoniales (Abstraído) -->
		<Testimonials />

		<Faq
			description="Todo lo que necesitas saber antes de comprar tu Google Pixel."
			items={faqs}
		/>
	</main>
</Layout>
