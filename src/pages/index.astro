---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import WarrantySupport from "../components/WarrantySupport.astro";
import { repairCatalog, formatPrice } from "../data/catalog";
import { phoneNumber } from "../data/store";
import { localBusinessSchema, faqSchema } from "../lib/seo";

const faqs = [
	{
		question: "¿Cuánto cuesta reparar la pantalla del Pixel 8 en México?",
		answer:
			"El cambio de pantalla OLED de excelente calidad réplica (con sensor de huellas activo) para la línea Pixel 8 tiene un costo de $2,900 MXN la refacción sola, o $3,700 MXN instalada. El tiempo de entrega de importación oficial es de 10-12 días hábiles.",
	},
	{
		question: "¿Dónde puedo cambiar la batería de un Google Pixel?",
		answer:
			"En Pixel Fix realizamos el cambio de pila original nueva. Para las series Pixel 6 y 7, el costo es de $1,400 MXN la refacción sola o $2,200 MXN con instalación especializada. Las de la serie 8 cuestan $1,600 MXN ($2,400 MXN instalada). El tiempo de importación es de 10-12 días hábiles.",
	},
	{
		question: "¿Qué garantía tienen las reparaciones y refacciones de Pixel?",
		answer:
			"Cualquier compra de refacciones o reparación instalada cuenta únicamente con **28 días de garantía** directa local en Monterrey. Transcurrido este plazo de 28 días, no se aceptan devoluciones ni cambios bajo ninguna circunstancia.",
	},
	{
		question:
			"¿Las refacciones de Google Pixel son originales y de dónde provienen?",
		answer:
			"Nuestras baterías son pilas originales nuevas de fábrica. Las pantallas son paneles OLED con lector de huella activo de calidad réplica excelente importadas de distribuidores en USA. Esto garantiza el óptimo desempeño del equipo a costos competitivos.",
	},
	{
		question:
			"¿Cómo funciona el trámite de garantía con Google si estoy en México?",
		answer:
			"Gestionamos la logística de envío de tu Pixel a soporte oficial de Google en USA para versiones americanas/globales (fallas de hardware de fábrica, no accidentes), verificando tu IMEI. El costo de gestión del trámite depende del caso: fallas de pantalla en Pixel 8 ($3,300 MXN) o Pixel 9 Pro/XL ($4,000 MXN); pila inflada de Pixel 7a ($2,500 MXN); cambio de Pixel 9 Pro Fold a la Serie 10 ($6,000 a $10,500 MXN); o la gestión general de garantías vigentes de la Serie 9 ($2,500 MXN) o Serie 10 ($3,000 MXN).",
	},
];

const businessSchema = localBusinessSchema({
	name: "Pixel Fix México",
	description:
		"Especialistas en Reparación y Refacciones Google Pixel en México. Pantallas, tapas y baterías originales.",
	priceRange: "$$",
});

const questionsSchema = faqSchema(faqs);

// Generar una lista de productos para el catalog schema
const productsSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "ItemList",
	itemListElement: repairCatalog.flatMap((catalog, i) =>
		catalog.parts.map((part, j) => ({
			"@type": "ListItem",
			position: i * 3 + j + 1,
			item: {
				"@type": "Product",
				name: `${part.name} para ${part.model}`,
				description: `Refacción importada y oficial para ${part.model}. Tiempo de entrega: ${part.delivery}.`,
				offers: {
					"@type": "Offer",
					priceCurrency: "MXN",
					price: (part.pricePart + (part.ganancia || 0)).toString(),
					availability: "https://schema.org/InStock",
					seller: {
						"@type": "Organization",
						name: "Pixel Fix México",
					},
				},
			},
		})),
	),
});
---

<Layout
	title="Pixel Fix | Especialistas Google Pixel en México"
	description="Reparación y venta de refacciones originales para Google Pixel. Pantallas, baterías y carcasas. Envíos nacionales y garantía en Monterrey."
	url="https://www.pixelfixmexico.com/"
>
	<script type="application/ld+json" set:html={businessSchema} />
	<script type="application/ld+json" set:html={questionsSchema} />
	<script type="application/ld+json" set:html={productsSchema} />

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section
			class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center gap-12 reveal"
		>
			<div class="flex-1 flex flex-col items-start text-left">
				<h1
					class="text-5xl md:text-[5rem] font-medium tracking-[-0.03em] text-ink leading-[1.05] mb-8"
				>
					Especialistas en Google Pixel.
				</h1>
				<p
					class="text-lg md:text-xl text-muted mb-10 leading-[1.6] max-w-lg font-light"
				>
					Reparación especializada y venta de equipos Google Pixel en México.
					Refacciones originales con garantía local y envíos a todo el país.
				</p>
				<div class="flex flex-wrap gap-4 mt-8 w-full">
					<a
						href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20cotizar%20un%20servicio%20o%20equipo.`}
						target="_blank"
						rel="noopener noreferrer"
						data-umami-event="hero_whatsapp_click"
						class="group inline-flex items-center justify-center px-6 py-3.5 bg-ink text-white text-xs font-mono font-medium rounded transition-transform hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>WhatsApp de Contacto</span>
						<Icon name="ph:arrow-right" class="w-3.5 h-3.5 ml-2 opacity-70 group-hover:opacity-100 transition-opacity" />
					</a>
					<a
						href="/reparacion-google-pixel-monterrey"
						data-umami-event="hero_reparacion_click"
						class="inline-flex items-center justify-center px-6 py-3.5 bg-white border border-border text-ink text-xs font-mono font-medium rounded hover:bg-surface-muted transition-all hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Reparación y Piezas</span>
					</a>
					<a
						href="/venta-google-pixel-monterrey"
						data-umami-event="hero_venta_click"
						class="inline-flex items-center justify-center px-6 py-3.5 bg-white border border-border text-ink text-xs font-mono font-medium rounded hover:bg-surface-muted transition-all hover:scale-[0.98] w-full sm:w-auto"
					>
						<span>Comprar Equipos</span>
					</a>
				</div>
			</div>
			<div class="flex-1 w-full relative h-[400px] md:h-[500px]">
				<!-- Taste-skill standard: highly desaturated image with subtle grain/overlay -->
				<div
					class="absolute inset-0 bg-surface-muted border border-border rounded-xl overflow-hidden"
				>
					<img
						src="/hero-repair.jpg"
						alt="Refacciones y servicio para Google Pixel"
						fetchpriority="high"
						loading="eager"
						class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply"
					/>
					<div class="absolute inset-0 bg-ink opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Selector de Modelos y Precios -->
		<section
			id="cotizador"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-border reveal"
		>
			<div class="mb-12 max-w-2xl">
				<h2
					class="text-3xl md:text-4xl tracking-tight text-ink mb-4"
				>
					Catálogo y Cotizador.
				</h2>
				<p class="text-muted leading-[1.6] mb-4">
					Refacciones OEM y mano de obra experta para tu Google Pixel.
					Importamos piezas directamente desde EE. UU., y **estamos trabajando
					activamente para tener en stock local inmediato las refacciones más
					solicitadas**. Confía en nosotros.
				</p>
				<div class="flex flex-wrap gap-2">
					<div
						class="inline-flex items-center px-3 py-1.5 bg-surface-muted border border-border rounded font-mono text-xs text-ink"
					>
						<span class="w-1.5 h-1.5 rounded-full bg-ink mr-2"></span>
						Piezas originales y calidad OEM. Todas las refacciones son importadas
						y oficiales.
					</div>
					<div
						class="inline-flex items-center px-3 py-1.5 bg-success-soft border border-success-border rounded font-mono text-xs text-success"
					>
						<span class="w-1.5 h-1.5 rounded-full bg-success mr-2"></span>
						<span
							><strong>¡Promoción Combo!</strong> Pantalla + Pila juntas en el mismo
							equipo: instalación a <strong>$800 MXN</strong> total (ahorras $800).</span
						>
					</div>
				</div>
			</div>

			<!-- Selector de Series -->
			<div class="flex justify-center mb-10 w-full max-w-xs mx-auto">
				<div class="relative w-full">
					<select
						id="model-select"
						data-umami-event="cotizador_select_changed"
						class="w-full bg-white border border-border rounded-lg px-4 py-3 text-sm font-medium text-ink appearance-none cursor-pointer focus:outline-none focus:ring-1 focus:ring-ink focus:border-ink transition-all shadow-[0_2px_8px_rgba(0,0,0,0.02)]"
					>
						{
							repairCatalog.map((catalog, index) => (
								<option value={catalog.id} selected={index === 2}>
									{catalog.series}
								</option>
							))
						}
					</select>
					<div
						class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-muted"
					>
						<Icon name="ph:caret-down" class="h-4 w-4" />
					</div>
				</div>
			</div>

			<!-- Tab Contents -->
			<div class="relative min-h-[300px]">
				{
					repairCatalog.map((catalog, index) => (
						<div
							class={`tab-content grid grid-cols-1 md:grid-cols-2 gap-6 ${index === 2 ? "" : "hidden"}`}
							id={catalog.id}
						>
							{catalog.parts.map((part) => (
								<div class="bg-surface p-6 border border-border rounded-xl flex flex-col justify-between transition-all hover:shadow-[0_4px_12px_rgba(0,0,0,0.03)] hover:border-border-strong">
									<div>
										<div class="flex items-center justify-between gap-2 mb-4 border-b border-bg pb-3">
											<span class="text-xs font-mono font-medium text-ink bg-surface-muted border border-border px-2 py-0.5 rounded-full">
												{part.model}
											</span>
											<span class="text-xs font-mono text-warning bg-warning-soft px-2 py-0.5 rounded">
												{part.delivery}
											</span>
										</div>
										<h3 class="text-lg font-semibold text-ink leading-snug mb-4">
											{part.name}
										</h3>

										<div class="space-y-3 text-sm text-muted mb-6">
											<div class="flex justify-between border-b border-bg/50 pb-2">
												<span>Refacción sola:</span>
												<span class="font-medium text-ink font-mono">
													{formatPrice(part.pricePart, part.ganancia)}
												</span>
											</div>
											<div class="flex justify-between pb-1">
												<span>Con instalación en MTY:</span>
												<span class="font-medium text-ink font-mono">
													{formatPrice(part.priceInstall, part.ganancia)}
												</span>
											</div>
										</div>
									</div>

									<a
										href="#"
										data-msg={`Hola Pixel Fix, quiero solicitar reparación / compra para la ${part.name} del ${part.model}. Pásame los detalles.`}
										data-umami-event="cotizar_reparacion_click"
										data-umami-event-model={part.model}
										data-umami-event-part={part.name}
										class="wa-link block w-full text-center py-3 bg-ink hover:bg-ink-hover text-white text-xs font-mono font-medium rounded transition-transform hover:scale-[0.98]"
									>
										Cotizar Servicio
									</a>
								</div>
							))}
						</div>
					))
				}
			</div>
		</section>

		<ProcessSteps
			title="El Proceso de Confianza."
			description="Hacer reparar tu Pixel no tiene que ser un dolor de cabeza. Todo fluye de forma simple y transparente."
			steps={[
				{ title: "Cotizas por WhatsApp", description: "Selecciona la pieza que necesitas y te enviamos un resumen de tu orden sin compromisos." },
				{ title: "Envío o Instalación", description: "Nos envías tu equipo, compras la refacción para envío nacional, o agendas cita en MTY." },
				{ title: "Reparado y Garantizado", description: "Te devolvemos el equipo reparado con garantía directa en Monterrey." },
			]}
		/>

		<!-- Cláusula de Confianza Logística -->
		<div class="max-w-5xl mx-auto px-6 -mt-12 mb-24 reveal">
			<div class="bg-surface p-8 border border-border rounded-xl flex flex-col md:flex-row items-start gap-6">
				<div class="bg-danger-soft text-danger p-3 rounded shrink-0 border border-danger-soft">
					<Icon name="ph:lock-simple" class="w-5 h-5" />
				</div>
				<div>
					<h3 class="text-base font-medium text-ink mb-2">Garantía Real Local</h3>
					<p class="text-sm text-muted leading-[1.6]">
						¿No estás en Monterrey? Nos mandas tu equipo por paquetería asegurada. Todas nuestras
						reparaciones y piezas cuentan con garantía directa gestionada localmente, sin que tengas
						que pelear con proveedores extranjeros.
					</p>
				</div>
			</div>
		</div>

		<WarrantySupport />

		<!-- Testimoniales -->
		<Testimonials />

		<!-- Direct Answer FAQ Block (Extractable Content for AI) -->
		<section
			id="faq"
			class="max-w-3xl mx-auto px-6 py-24 border-t border-border reveal"
		>
			<div class="mb-12">
				<h2
					class="text-3xl tracking-tight text-ink mb-4"
				>
					Dudas Frecuentes.
				</h2>
				<p class="text-muted leading-[1.6]">
					Respuestas directas sobre nuestro servicio de reparación Pixel.
				</p>
			</div>

			<div class="space-y-6">
				{
					faqs.map((faq) => (
						<div class="pb-6 border-b border-border">
							<h3 class="text-lg font-medium text-ink mb-3">
								{faq.question}
							</h3>
							<p class="text-muted text-sm leading-[1.6]">{faq.answer}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<script>
	import { phoneNumber as PHONE_NUMBER } from "../data/store";

	// Model Selector Logic
	const modelSelect = document.getElementById("model-select");
	const contents = document.querySelectorAll(".tab-content");

	if (modelSelect) {
		modelSelect.addEventListener("change", (e) => {
			const targetId = (e.target as HTMLSelectElement).value;
			contents.forEach((c) => c.classList.add("hidden"));
			const targetEl = document.getElementById(targetId);
			if (targetEl) targetEl.classList.remove("hidden");
		});
	}

	// WhatsApp Links Builder
	const waLinks = document.querySelectorAll(".wa-link");

	waLinks.forEach((link) => {
		const msg = link.getAttribute("data-msg");
		if (msg) {
			link.setAttribute(
				"href",
				`https://wa.me/${PHONE_NUMBER}?text=${encodeURIComponent(msg)}`,
			);
			link.setAttribute("target", "_blank");
			link.setAttribute("rel", "noopener noreferrer");
		}
	});

</script>
