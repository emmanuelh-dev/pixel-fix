---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

let testimonialImages = [];
try {
  const testimonialsDir = path.join(process.cwd(), 'public/testimonials');
  if (fs.existsSync(testimonialsDir)) {
    testimonialImages = fs.readdirSync(testimonialsDir)
      .filter(file => /\.(png|jpe?g|webp|svg|gif)$/i.test(file))
      .map(file => `/testimonials/${file}`);
  }
} catch (e) {
  console.error("Error reading testimonials:", e);
}

// Array to easily manage products, models, and prices
const repairCatalog = [
  {
    series: "Pixel 10 Series",
    id: "pixel-10",
    parts: [
      { name: "Pantalla Original / OEM", model: "Pixel 10 / 10 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" },
      { name: "Batería Nueva Original", model: "Pixel 10 / 10 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" },
      { name: "Carcasa Trasera", model: "Pixel 10 / 10 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" }
    ]
  },
  {
    series: "Pixel 9 Series",
    id: "pixel-9",
    parts: [
      { name: "Pantalla Original / OEM", model: "Pixel 9 / 9 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" },
      { name: "Batería Nueva Original", model: "Pixel 9 / 9 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" },
      { name: "Carcasa Trasera", model: "Pixel 9 / 9 Pro", pricePart: "$ Cotizar", priceInstall: "$ Cotizar", delivery: "10-12 días hábiles" }
    ]
  },
  {
    series: "Pixel 8 Series",
    id: "pixel-8",
    parts: [
      { name: "Pantalla Original / OEM", model: "Pixel 8 / 8 Pro", pricePart: "$4,800 MXN", priceInstall: "$5,400 MXN", delivery: "10-12 días hábiles" },
      { name: "Batería Nueva Original", model: "Pixel 8 / 8 Pro", pricePart: "$1,400 MXN", priceInstall: "$1,900 MXN", delivery: "10-12 días hábiles" },
      { name: "Carcasa Trasera", model: "Pixel 8 / 8 Pro", pricePart: "$2,500 MXN", priceInstall: "$3,000 MXN", delivery: "10-12 días hábiles" }
    ]
  },
  {
    series: "Pixel 7 Series",
    id: "pixel-7",
    parts: [
      { name: "Pantalla Original / OEM", model: "Pixel 7 / 7 Pro", pricePart: "$4,000 MXN", priceInstall: "$4,600 MXN", delivery: "10-12 días hábiles" },
      { name: "Batería Nueva Original", model: "Pixel 7 / 7 Pro", pricePart: "$1,300 MXN", priceInstall: "$1,800 MXN", delivery: "10-12 días hábiles" },
      { name: "Carcasa Trasera", model: "Pixel 7 / 7 Pro", pricePart: "$2,000 MXN", priceInstall: "$2,500 MXN", delivery: "10-12 días hábiles" }
    ]
  },
  {
    series: "Pixel 6 Series",
    id: "pixel-6",
    parts: [
      { name: "Pantalla Original / OEM", model: "Pixel 6 / 6 Pro", pricePart: "$4,800 MXN", priceInstall: "$5,400 MXN", delivery: "10-12 días hábiles" },
      { name: "Batería Nueva Original", model: "Pixel 6 / 6 Pro", pricePart: "$1,300 MXN", priceInstall: "$1,800 MXN", delivery: "10-12 días hábiles" },
      { name: "Carcasa Trasera", model: "Pixel 6 / 6 Pro", pricePart: "$1,800 MXN", priceInstall: "$2,300 MXN", delivery: "10-12 días hábiles" }
    ]
  }
];

const faqs = [
  {
    question: "¿Cuánto cuesta reparar la pantalla del Pixel 8 en México?",
    answer: "El cambio de pantalla original o calidad OEM para la línea Pixel 8 tiene un costo promedio desde $4,800 MXN la refacción sola, o $5,400 MXN con instalación especializada en nuestro laboratorio de Monterrey. El tiempo de entrega oficial de importación es de 10-12 días hábiles."
  },
  {
    question: "¿Dónde puedo cambiar la batería de un Google Pixel?",
    answer: "En Pixel Fix somos especialistas. Realizamos el cambio de batería original para líneas Pixel 6, 7, 8, 9 y 10 desde $1,300 MXN la refacción o $1,800 MXN con instalación, y te ofrecemos garantía directa en México."
  },
  {
    question: "¿Qué garantía tienen las reparaciones y refacciones de Pixel?",
    answer: "Todas las piezas que instalamos o enviamos son de importación oficial o de calidad OEM. Cuentan con garantía real gestionada localmente en Monterrey, sin que el cliente tenga que tramitar devoluciones con intermediarios o proveedores extranjeros."
  }
];

const phoneNumber = "528111913676";

// Generar LD+JSON Scripts estáticos para Astro
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Pixel Fix México",
  "image": "https://www.pixelfixmexico.com/logo.png",
  "description": "Especialistas en Reparación y Refacciones Google Pixel en México. Pantallas, tapas y baterías originales.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Monterrey",
    "addressRegion": "NL",
    "addressCountry": "MX"
  },
  "priceRange": "$$",
  "telephone": `+${phoneNumber}`
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
});

// Generar una lista de productos para el catalog schema
const productsSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": repairCatalog.flatMap((catalog, i) => 
    catalog.parts.map((part, j) => ({
      "@type": "ListItem",
      "position": i * 3 + j + 1,
      "item": {
        "@type": "Product",
        "name": `${part.name} para ${part.model}`,
        "description": `Refacción importada y oficial para ${part.model}. Tiempo de entrega: ${part.delivery}.`,
        "offers": {
          "@type": "Offer",
          "priceCurrency": "MXN",
          "price": part.pricePart.replace(/[^0-9.]/g, '') || "0",
          "availability": "https://schema.org/InStock",
          "seller": {
            "@type": "Organization",
            "name": "Pixel Fix México"
          }
        }
      }
    }))
  )
});
---

<Layout 
	title="Pixel Fix | Especialistas Google Pixel en México"
	description="Reparación y venta de refacciones originales para Google Pixel. Pantallas, baterías y carcasas. Envíos nacionales y garantía en Monterrey."
>
	<script type="application/ld+json" set:html={localBusinessSchema} />
	<script type="application/ld+json" set:html={faqSchema} />
	<script type="application/ld+json" set:html={productsSchema} />

	<!-- Subtle ambient background for entire page -->
	<div class="fixed inset-0 pointer-events-none z-[-1] bg-[#FBFBFA]">
		<div class="absolute inset-0 opacity-[0.03] animate-[pulse_20s_ease-in-out_infinite]" style="background: radial-gradient(circle at 50% 0%, #111111 0%, transparent 60%);"></div>
	</div>

	<!-- Header -->
	<header class="w-full border-b border-[#EAEAEA] bg-[#FBFBFA]/80 backdrop-blur-md sticky top-0 z-50">
		<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
			<div class="font-bold text-[#111111] tracking-tight">Pixel Fix.</div>
			<nav class="hidden md:flex items-center gap-8 text-sm text-[#787774]">
				<a href="#cotizador" class="hover:text-[#111111] transition-colors">Cotizador</a>
				<a href="#proceso" class="hover:text-[#111111] transition-colors">Proceso</a>
				<a href="#testimoniales" class="hover:text-[#111111] transition-colors">Testimoniales</a>
				<a href="#faq" class="hover:text-[#111111] transition-colors">Dudas Frecuentes</a>
			</nav>
			<a href={`https://wa.me/${phoneNumber}`} target="_blank" class="px-4 py-2 bg-[#111111] text-white text-xs font-medium rounded transition-transform hover:scale-[0.98]">
				Contacto
			</a>
		</div>
	</header>

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center gap-12 reveal">
			<div class="flex-1 flex flex-col items-start text-left">
				<h1 class="font-serif-editorial text-5xl md:text-[5rem] font-medium tracking-[-0.03em] text-[#111111] leading-[1.05] mb-8">
					Reparación Google Pixel en Monterrey.
				</h1>
				<p class="text-lg md:text-xl text-[#787774] mb-10 leading-[1.6] max-w-lg font-light">
					Piezas originales con garantía local y envíos a todo el país. Basados en Monterrey.
				</p>
				<a href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20cotizar%20una%20reparaci%C3%B3n.`} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center px-8 py-4 bg-[#111111] text-white text-sm font-medium rounded transition-transform hover:scale-[0.98]">
					<span>Cotizar mi reparación por WhatsApp</span>
					<svg class="w-4 h-4 ml-3 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
					</svg>
				</a>
			</div>
			<div class="flex-1 w-full relative h-[400px] md:h-[500px]">
				<!-- Taste-skill standard: highly desaturated image with subtle grain/overlay -->
				<div class="absolute inset-0 bg-[#F9F9F8] border border-[#EAEAEA] rounded-xl overflow-hidden">
					<img src="https://picsum.photos/seed/pixelrepair/800/1000" alt="Refacciones y servicio para Google Pixel" class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply" />
					<div class="absolute inset-0 bg-[#111111] opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Selector de Modelos y Precios -->
		<section id="cotizador" class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal">
			<div class="mb-12 max-w-2xl">
				<h2 class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4">Catálogo y Cotizador.</h2>
				<p class="text-[#787774] leading-[1.6] mb-4">Refacciones OEM y mano de obra experta para tu Google Pixel.</p>
				<div class="inline-flex items-center px-3 py-1.5 bg-[#F9F9F8] border border-[#EAEAEA] rounded font-mono text-xs text-[#111111] mb-2">
					<span class="w-1.5 h-1.5 rounded-full bg-[#111111] mr-2"></span>
					Piezas originales y calidad OEM. Todas las refacciones son importadas y oficiales.
				</div>
			</div>

			<!-- Tabs -->
			<div class="flex flex-wrap gap-2 mb-10" id="model-tabs">
				{repairCatalog.map((catalog, index) => (
					<button class={`tab-btn px-5 py-2.5 rounded text-sm transition-all duration-200 ${index === 2 ? 'bg-[#111111] text-white active-tab' : 'bg-[#FFFFFF] border border-[#EAEAEA] text-[#787774] hover:bg-[#F9F9F8]'}`} data-target={catalog.id}>
						{catalog.series}
					</button>
				))}
			</div>

			<!-- Tab Contents -->
			<div class="relative min-h-[300px]">
				{repairCatalog.map((catalog, index) => (
					<div class={`tab-content grid gap-6 ${index === 2 ? '' : 'hidden'}`} id={catalog.id}>
						{catalog.parts.map(part => (
							<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row md:items-start justify-between gap-8 transition-shadow hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]">
								<div class="flex-1">
									<div class="flex items-center gap-3 mb-4">
										<h3 class="text-xl font-medium text-[#111111]">{part.name}</h3>
										<span class="text-[10px] uppercase tracking-[0.05em] font-medium text-[#111111] bg-[#F9F9F8] border border-[#EAEAEA] px-2 py-0.5 rounded-full">{part.model}</span>
									</div>
									<div class="space-y-4 text-sm text-[#787774]">
										<div class="flex justify-between border-b border-[#EAEAEA] pb-3">
											<span>Refacción sola:</span>
											<span class="font-medium text-[#111111] font-mono">{part.pricePart}</span>
										</div>
										<div class="flex justify-between border-b border-[#EAEAEA] pb-3">
											<span>Con instalación en MTY:</span>
											<span class="font-medium text-[#111111] font-mono">{part.priceInstall}</span>
										</div>
										<div class="flex justify-between pt-1">
											<span>Tiempo de entrega oficial:</span>
											<span class="font-medium text-[#956400]">{part.delivery}</span>
										</div>
									</div>
								</div>
								<div class="w-full md:w-64 shrink-0 flex flex-col gap-3 justify-center">
									<a href="#" data-msg={`Hola Pixel Fix, quiero solicitar reparación / compra para la ${part.name} del ${part.model}. Pásame los detalles.`} class="wa-link text-center px-4 py-3 bg-[#111111] text-white text-sm font-medium rounded hover:scale-[0.98] transition-transform">Seleccionar y Solicitar Reparación</a>
								</div>
							</div>
						))}
					</div>
				))}
			</div>
		</section>

		<!-- El Proceso de Confianza & Logística -->
		<section id="proceso" class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal">
			<div class="mb-16 max-w-xl">
				<h2 class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4">El Proceso de Confianza.</h2>
				<p class="text-[#787774] leading-[1.6]">Hacer reparar tu Pixel no tiene que ser un dolor de cabeza. Todo fluye de forma simple y transparente.</p>
			</div>
			
			<div class="grid md:grid-cols-3 gap-6">
				<div class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col">
					<div class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded">01</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">Cotizas por WhatsApp</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">Selecciona la pieza que necesitas y te enviamos un resumen de tu orden sin compromisos.</p>
				</div>

				<div class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col">
					<div class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded">02</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">Envío o Instalación</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">Nos envías tu equipo, compras la refacción para envío nacional, o agendas cita en MTY.</p>
				</div>

				<div class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col">
					<div class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded">03</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">Reparado y Garantizado</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">Te devolvemos el equipo reparado con garantía directa en Monterrey.</p>
				</div>
			</div>

			<!-- Cláusula de Confianza Logística -->
			<div class="mt-12 bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row items-start gap-6">
				<div class="bg-[#FDEBEC] text-[#9F2F2D] p-3 rounded shrink-0 border border-[#FDEBEC]">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
				</div>
				<div>
					<h3 class="text-base font-medium text-[#111111] mb-2">Garantía Real Local</h3>
					<p class="text-sm text-[#787774] leading-[1.6]">
						¿No estás en Monterrey? Nos mandas tu equipo por paquetería asegurada. Todas nuestras reparaciones y piezas cuentan con garantía directa gestionada localmente, sin que tengas que pelear con proveedores extranjeros.
					</p>
				</div>
			</div>
		</section>

		<!-- Testimoniales -->
		<section id="testimoniales" class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal">
			<div class="mb-12 max-w-2xl">
				<h2 class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4">Lo Que Dicen Nuestros Clientes.</h2>
				<p class="text-[#787774] leading-[1.6]">Opiniones reales y capturas de conversaciones con clientes satisfechos que repararon su Google Pixel con nosotros.</p>
			</div>

			{testimonialImages.length > 0 ? (
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
					{testimonialImages.map((img) => (
						<div class="bg-[#FFFFFF] border border-[#EAEAEA] rounded-xl overflow-hidden shadow-[0_2px_8px_rgba(0,0,0,0.02)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 group">
							<div class="p-2 bg-[#F9F9F8] border-b border-[#EAEAEA] flex items-center justify-between text-[10px] text-[#787774] font-mono">
								<span>Evidencia Real</span>
								<a href={img} target="_blank" rel="noopener noreferrer" class="hover:text-[#111111] transition-colors underline">Ampliar</a>
							</div>
							<div class="relative overflow-hidden bg-[#FBFBFA] flex items-center justify-center p-4">
								<img 
									src={img} 
									alt="Captura de testimonio de reparación Google Pixel" 
									class="w-full h-auto max-h-[400px] object-contain rounded-lg border border-[#EAEAEA]/50 opacity-95 saturate-[0.85] contrast-[1.05] group-hover:scale-[1.01] transition-transform duration-500" 
									loading="lazy"
								/>
							</div>
						</div>
					))}
				</div>
			) : (
				<div class="border border-dashed border-[#EAEAEA] rounded-xl p-12 text-center text-sm text-[#787774] bg-[#F9F9F8]/50">
					<p class="mb-2 font-mono">No hay capturas de testimoniales cargadas aún.</p>
					<p class="text-xs text-[#787774]">Coloca capturas de WhatsApp o Google Maps en la carpeta <code class="bg-[#F7F6F3] px-1 py-0.5 rounded border border-[#EAEAEA] text-xs font-mono">public/testimonials/</code> y aparecerán aquí automáticamente.</p>
				</div>
			)}
		</section>

		<!-- Direct Answer FAQ Block (Extractable Content for AI) -->
		<section id="faq" class="max-w-3xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal">
			<div class="mb-12">
				<h2 class="font-serif-editorial text-3xl tracking-tight text-[#111111] mb-4">Dudas Frecuentes.</h2>
				<p class="text-[#787774] leading-[1.6]">Respuestas directas sobre nuestro servicio de reparación Pixel.</p>
			</div>

			<div class="space-y-6">
				{faqs.map(faq => (
					<div class="pb-6 border-b border-[#EAEAEA]">
						<h3 class="text-lg font-medium text-[#111111] mb-3">{faq.question}</h3>
						<p class="text-[#787774] text-sm leading-[1.6]">{faq.answer}</p>
					</div>
				))}
			</div>
		</section>
		
		<!-- Footer -->
		<footer class="py-12 border-t border-[#EAEAEA] bg-[#FBFBFA]">
			<div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-[#787774] font-mono">
				<div>
					<p class="mb-1">© 2026 Pixel Fix. Especialistas Google Pixel.</p>
					<p class="text-[10px] opacity-70">Precios y stock actualizados a {new Date().toLocaleString('es-MX', { month: 'long', year: 'numeric' })}.</p>
					<p class="text-[10px] opacity-70 mt-2">Tecnología y logística respaldada por <a href="/respaldo-bysmax" class="underline hover:text-[#111111]">Bysmax</a> (<a href="https://bysmax.com" target="_blank" rel="noopener" class="hover:text-[#111111] transition-colors">Empresa de Desarrollo de Software en Monterrey</a>).</p>
				</div>
				<div class="flex gap-6">
					<a href="#" class="hover:text-[#111111] transition-colors">Términos y Condiciones</a>
					<a href="#" class="hover:text-[#111111] transition-colors">Política de Privacidad</a>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<script>
	// Tab Switching Logic
	const tabs = document.querySelectorAll('.tab-btn');
	const contents = document.querySelectorAll('.tab-content');

	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			tabs.forEach(t => {
				t.classList.remove('bg-[#111111]', 'text-white', 'active-tab');
				t.classList.add('bg-[#FFFFFF]', 'border', 'border-[#EAEAEA]', 'text-[#787774]');
			});
			contents.forEach(c => c.classList.add('hidden'));

			tab.classList.remove('bg-[#FFFFFF]', 'border', 'border-[#EAEAEA]', 'text-[#787774]');
			tab.classList.add('bg-[#111111]', 'text-white', 'active-tab');
			const targetId = tab.getAttribute('data-target');
			const targetEl = document.getElementById(targetId);
			if (targetEl) targetEl.classList.remove('hidden');
		});
	});

	// WhatsApp Links Builder
	const PHONE_NUMBER = "528111913676"; 
	const waLinks = document.querySelectorAll('.wa-link');
	
	waLinks.forEach(link => {
		const msg = link.getAttribute('data-msg');
		if(msg) {
			link.setAttribute('href', `https://wa.me/${PHONE_NUMBER}?text=${encodeURIComponent(msg)}`);
			link.setAttribute('target', '_blank');
			link.setAttribute('rel', 'noopener noreferrer');
		}
	});

	// Scroll Reveal Animations using IntersectionObserver
	const observerOptions = {
		root: null,
		rootMargin: '0px',
		threshold: 0.1
	};

	const observer = new IntersectionObserver((entries, observer) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('revealed');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	document.querySelectorAll('.reveal').forEach(el => {
		observer.observe(el);
	});
</script>

