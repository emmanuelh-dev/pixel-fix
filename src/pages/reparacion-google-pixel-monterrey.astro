---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import WarrantySupport from "../components/WarrantySupport.astro";
import { phoneNumber } from "../data/store";
import { localBusinessSchema, faqSchema } from "../lib/seo";
import Store from "../components/Store.astro";

const faqs = [
	{
		question: "¿Cuánto cuesta reparar la pantalla del Pixel 8 en México?",
		answer:
			"El cambio de pantalla OLED de excelente calidad réplica (con sensor de huellas activo) para la línea Pixel 8 tiene un costo de $2,900 MXN la refacción sola, o $3,700 MXN instalada. El tiempo de entrega de importación oficial es de 10-12 días hábiles.",
	},
	{
		question: "¿Dónde puedo cambiar la batería de un Google Pixel?",
		answer:
			"En Pixel Fix realizamos el cambio de pila original nueva. Para las series Pixel 6 y 7, el costo es de $1,400 MXN la refacción sola o $2,200 MXN con instalación especializada. Las pilas originales de la serie 8 cuestan $1,600 MXN ($2,400 MXN instalada). El tiempo de importación es de 10-12 días hábiles.",
	},
	{
		question: "¿Qué garantía tienen las reparaciones y refacciones de Pixel?",
		answer:
			"Cualquier compra de refacciones o reparación instalada cuenta únicamente con **28 días de garantía** directa local en Monterrey. Transcurrido este plazo de 28 días, no se aceptan devoluciones ni cambios bajo ninguna circunstancia.",
	},
	{
		question:
			"¿Las refacciones de Google Pixel son originales y de dónde provienen?",
		answer:
			"Nuestras baterías son pilas originales nuevas de fábrica. Las pantallas son paneles OLED con lector de huella activo de calidad réplica excelente importadas de distribuidores en USA. Esto garantiza el óptimo desempeño del equipo a costos competitivos.",
	},
	{
		question:
			"¿Cómo funciona el trámite de garantía con Google si estoy en México?",
		answer:
			"Gestionamos la logística de envío de tu Pixel a soporte oficial de Google en USA para versiones americanas/globales (fallas de hardware de fábrica, no accidentes), verificando tu IMEI. El costo de gestión del trámite depende del caso: fallas de pantalla en Pixel 8 ($3,300 MXN) o Pixel 9 Pro/XL ($4,000 MXN); pila inflada de Pixel 7a ($2,500 MXN); cambio de Pixel 9 Pro Fold a la Serie 10 ($6,000 a $10,500 MXN); o la gestión general de garantías vigentes de la Serie 9 ($2,500 MXN) o Serie 10 ($3,000 MXN).",
	},
	{
		question: "¿Son un servicio técnico autorizado de Google Pixel en Monterrey o México?",
		answer:
			"No somos un centro de servicio técnico autorizado por Google. Somos un laboratorio independiente altamente especializado. A diferencia de opciones multimarca en Monterrey como Hospital Celular o Simtech, nos enfocamos exclusivamente en la marca Google Pixel, ofreciendo reparación experta y venta de repuestos originales o piezas OEM de la misma cadena de distribución de iFixit en USA.",
	},
	{
		question: "¿Dónde comprar repuestos originales de Google Pixel en Monterrey?",
		answer:
			"En Pixel Fix Monterrey somos la tienda líder en venta e instalación de piezas y repuestos originales Google Pixel en México. Puedes adquirir pantallas OLED (con sensor de huella activo) y baterías originales nuevas, con opción de instalación en nuestro taller o envío nacional express asegurado por DHL.",
	},
];

const businessSchema = localBusinessSchema({
	name: "Pixel Fix México",
	description:
		"Especialistas en Reparación de Google Pixel en Monterrey. Pantallas, tapas y baterías originales.",
	priceRange: "$$",
});

const questionsSchema = faqSchema(faqs);
---

<Layout
	title="Reparación Google Pixel en Monterrey | Especialistas Pixel Fix"
	description="Servicio técnico especializado para Google Pixel en Monterrey. Cambio de pantalla, batería y tapas originales con garantía directa local."
	image="https://www.pixelfixmexico.com/og-image-reparaciones.jpg"
	url="https://www.pixelfixmexico.com/reparacion-google-pixel-monterrey/"
>
	<script type="application/ld+json" set:html={businessSchema} />
	<script type="application/ld+json" set:html={questionsSchema} />

	<main class="min-h-screen">
		<!-- Hero compacto: copy + trust pills, sin imagen que robe viewport -->
		<section class="max-w-5xl mx-auto px-6 pt-10 pb-6">
			<div
				class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
			>
				<div class="max-w-xl">
					<span
						class="inline-flex items-center gap-2 px-3 py-1 bg-accent-soft text-accent text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-4"
					>
						Especialistas Google Pixel · Monterrey
					</span>
					<h1
						class="text-4xl md:text-5xl font-medium tracking-tight text-ink leading-[1.05] mb-3"
					>
						Reparación Google Pixel<br />en Monterrey.
					</h1>
					<p class="text-base text-muted leading-relaxed max-w-md">
						Pantallas, baterías y tapas originales. Garantía local directa.
						Envío a todo México.
					</p>
				</div>
				<!-- Trust pills verticales en desktop -->
				<div class="flex flex-row md:flex-col gap-2 flex-wrap">
					<div
						class="inline-flex items-center gap-2 px-3 py-1.5 bg-success-soft border border-success-border rounded-lg text-xs text-success font-mono"
					>
						<span class="w-1.5 h-1.5 rounded-full bg-success flex-shrink-0"
						></span>
						Instalación $800 MXN
					</div>
					<div
						class="inline-flex items-center gap-2 px-3 py-1.5 bg-surface-muted border border-border rounded-lg text-xs text-muted font-mono"
					>
						<span class="w-1.5 h-1.5 rounded-full bg-ink flex-shrink-0"
						></span>
						28 días garantía · Envío $250 MXN
					</div>
					<a
						href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20cotizar%20la%20reparaci%C3%B3n%20de%20mi%20Google%20Pixel%20en%20Monterrey.`}
						target="_blank"
						rel="noopener noreferrer"
						data-umami-event="repairs_hero_whatsapp_click"
						class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-whatsapp text-white text-xs font-medium rounded-lg hover:bg-whatsapp-hover transition-colors whitespace-nowrap"
					>
						<Icon name="simple-icons:whatsapp" class="w-4 h-4" />
						Cotizar por WhatsApp
					</a>
				</div>
			</div>
		</section>

		<!-- Banner garantía Google USA -->
		{(() => {
			const waGarantia = `https://wa.me/${phoneNumber}?text=${encodeURIComponent("Hola, me interesa el servicio de garantía con Google USA. ¿Cómo funciona?")}`;
			return (
				<section class="max-w-5xl mx-auto px-6 mb-6">
					<div class="rounded-2xl border border-border-strong bg-white overflow-hidden">
						<div class="px-5 py-4 border-b border-border flex items-center gap-3">
							<span class="text-base">🛡️</span>
							<div>
								<p class="text-sm font-semibold text-ink leading-snug">
									Manda tu Pixel a garantía con Google <span class="font-normal text-muted-strong">Estados Unidos</span>
								</p>
								<p class="text-xs text-muted-strong mt-0.5">
									Trámite directo con Google USA — <span class="text-ink font-medium">garantía vigente al momento del envío</span> · nosotros gestionamos todo
								</p>
								<div class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
									<span class="text-[11px] text-muted-strong flex items-center gap-1">
										<span class="inline-block w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
										Línea en pantalla — todos los Pixel 8 aplican
									</span>
									<span class="text-[11px] text-muted-strong flex items-center gap-1">
										<span class="inline-block w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
										Garantía activa 2025 o 2026
									</span>
								</div>
							</div>
							<a
								href={waGarantia}
								target="_blank"
								rel="noopener noreferrer"
								class="ml-auto whitespace-nowrap px-3 py-2 bg-ink text-white text-[11px] font-mono rounded-lg hover:bg-ink-hover transition-colors flex-shrink-0"
							>
								Consultar
							</a>
						</div>
						<div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-y sm:divide-y-0 divide-border">
							{[
								{ model: "Pixel 8 (todos)", detail: "Línea en pantalla", price: "$2,950" },
								{ model: "Pixel 9 Pro / 9 XL", detail: "Pantalla", price: "$3,850" },
								{ model: "Pixel 7a", detail: "Batería", price: "$2,000" },
								{ model: "Garantía general", detail: "Cualquier Pixel vigente", price: "$2,800" },
							].map(({ model, detail, price }) => (
								<div class="px-4 py-3.5 flex flex-col gap-0.5">
									<span class="text-[10px] font-mono text-muted-strong uppercase tracking-wider">{model}</span>
									<span class="text-[11px] text-muted">{detail}</span>
									<span class="text-sm font-bold font-mono text-ink mt-1">{price} <span class="text-[10px] font-normal text-muted-strong">MXN</span></span>
								</div>
							))}
						</div>
					</div>
				</section>
			);
		})()}

		<Store categoryFilter="refaccion" />
		<!-- Enlace contextual a ventas -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div
				class="bg-surface p-8 border border-border rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
			>
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-ink mb-2">
						¿Prefieres renovar tu dispositivo?
					</h3>
					<p class="text-sm text-muted leading-[1.6]">
						Si la reparación no es viable o prefieres actualizar tu teléfono,
						contamos con un catálogo curado de <a
							href="/equipos"
							data-umami-event="repairs_contextual_sales_link_click"
							class="text-ink underline hover:text-accent transition-colors"
							>celulares Google Pixel Usados Estética 9 y Open Box</a
						> con garantía local directa.
					</p>
				</div>
				<a
					href="/equipos"
					data-umami-event="repairs_go_to_sales_click"
					class="px-6 py-3.5 bg-ink text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0"
				>
					Ver Equipos en Venta
				</a>
			</div>
		</section>

		<ProcessSteps
			title="Proceso de Servicio."
			description="Repara tu dispositivo de manera transparente y con técnicos capacitados."
			steps={[
				{ title: "Envías o Agendas", description: "Nos contactas por WhatsApp para agendar tu cita física en Monterrey o coordinar envío por paquetería." },
				{ title: "Diagnóstico y Reparación", description: "Instalamos las refacciones originales o calidad OEM seleccionadas bajo estrictos controles técnicos." },
				{ title: "Garantía Directa", description: "Te devolvemos tu Google Pixel reparado con sello de garantía local en Monterrey." },
			]}
		/>

		<WarrantySupport />

		<!-- Testimoniales (Abstraído) -->
		<Testimonials />

		<Faq
			description="Respuestas sobre el servicio técnico y garantía local."
			items={faqs}
		/>
	</main>
</Layout>
