<script>
	// --- Chip filters ---
	let repType = "all",
		repModel = "all";

	function applyRepFilter() {
		const cards = document.querySelectorAll(".rep-card");
		let visible = 0;
		cards.forEach((card) => {
			const el = card as HTMLElement;
			const matchType = repType === "all" || el.dataset.type === repType;
			const matchModel = repModel === "all" || el.dataset.model === repModel;
			const show = matchType && matchModel;
			el.style.display = show ? "" : "none";
			if (show) visible++;
		});
		const countEl = document.getElementById("rep-count");
		if (countEl)
			countEl.textContent = `${visible} pieza${visible !== 1 ? "s" : ""}`;
		const noRes = document.getElementById("rep-no-results");
		const grid = document.getElementById("rep-grid");
		if (noRes) noRes.classList.toggle("hidden", visible > 0);
		if (grid) grid.classList.toggle("hidden", visible === 0);
	}

	function activateRepChip(cls: string, selected: Element) {
		document.querySelectorAll(`.${cls}`).forEach((b) => {
			b.className =
				b.className.replace(/r-chip-\w+/g, "").trim() +
				(b === selected ? " r-chip-active" : " r-chip-inactive");
		});
	}

	document
		.getElementById("rep-type-filters")
		?.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".rep-type-btn") as HTMLElement;
			if (!btn) return;
			repType = btn.dataset.type!;
			activateRepChip("rep-type-btn", btn);
			applyRepFilter();
		});

	document
		.getElementById("rep-model-filters")
		?.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(
				".rep-model-btn",
			) as HTMLElement;
			if (!btn) return;
			repModel = btn.dataset.model!;
			activateRepChip("rep-model-btn", btn);
			applyRepFilter();
		});

	// --- Carrito global (window.pfCart del Layout) ---
	document.getElementById("rep-grid")?.addEventListener("click", (e) => {
		const btn = (e.target as Element).closest(".add-btn") as HTMLElement;
		if (!btn || !window.pfCart) return;
		window.pfCart.toggle(
			btn.dataset.id!,
			btn.dataset.name!,
			btn.dataset.part!,
			Number(btn.dataset.price),
		);
	});

	// Scroll Reveal
	const observer = new IntersectionObserver(
		(entries, obs) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("revealed");
					obs.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1 },
	);
	document.querySelectorAll(".reveal").forEach((el) => {
		observer.observe(el);
	});
</script>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
			transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}
	.r-chip-active {
		background: #111111;
		color: white;
		border-color: #111111;
	}
	.r-chip-inactive {
		background: transparent;
		color: #787774;
		border-color: #eaeaea;
	}
	.r-chip-inactive:hover {
		border-color: #111111;
		color: #111111;
	}
</style>
