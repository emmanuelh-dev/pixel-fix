---
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import { repairCatalog, formatPrice } from "../data/catalog";

const faqs = [
	{
		question: "¿Cuánto cuesta reparar la pantalla del Pixel 8 en México?",
		answer:
			"El cambio de pantalla OLED de excelente calidad réplica (con sensor de huellas activo) para la línea Pixel 8 tiene un costo de $2,500 MXN la refacción sola, o $3,100 MXN instalada. El tiempo de entrega de importación oficial es de 10-12 días hábiles.",
	},
	{
		question: "¿Dónde puedo cambiar la batería de un Google Pixel?",
		answer:
			"En Pixel Fix realizamos el cambio de pila original nueva. Para las series Pixel 6 y 7, el costo es de $1,000 MXN la refacción sola o $1,500 MXN con instalación especializada. Las pilas originales de la serie 8 cuestan $1,200 MXN ($1,700 MXN instalada). El tiempo de importación es de 10-12 días hábiles.",
	},
	{
		question: "¿Qué garantía tienen las reparaciones y refacciones de Pixel?",
		answer:
			"Cualquier compra de refacciones o reparación instalada cuenta únicamente con **28 días de garantía** directa local en Monterrey. Transcurrido este plazo de 28 días, no se aceptan devoluciones ni cambios bajo ninguna circunstancia.",
	},
	{
		question: "¿Las refacciones de Google Pixel son originales y de dónde provienen?",
		answer:
			"Nuestras baterías son pilas originales nuevas de fábrica. Las pantallas son paneles OLED con lector de huella activo de calidad réplica excelente importadas de distribuidores en USA. Esto garantiza el óptimo desempeño del equipo a costos competitivos.",
	},
	{
		question: "¿Cómo funciona el trámite de garantía con Google si estoy en México?",
		answer:
			"Gestionamos la logística de envío de tu Pixel a soporte oficial de Google en USA para versiones americanas/globales (fallas de hardware de fábrica, no accidentes), verificando tu IMEI. El costo de gestión del trámite depende del caso: fallas de pantalla en Pixel 8 ($3,300 MXN) o Pixel 9 Pro/XL ($4,000 MXN); pila inflada de Pixel 7a ($2,500 MXN); cambio de Pixel 9 Pro Fold a la Serie 10 ($6,000 a $10,500 MXN); o la gestión general de garantías vigentes de la Serie 9 ($2,500 MXN) o Serie 10 ($3,000 MXN).",
	},
];

const phoneNumber = "528111913676";

// Generar LD+JSON Scripts estáticos para Astro
const localBusinessSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	name: "Pixel Fix México",
	image: "https://www.pixelfixmexico.com/logo.png",
	description:
		"Especialistas en Reparación de Google Pixel en Monterrey. Pantallas, tapas y baterías originales.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Monterrey",
		addressRegion: "NL",
		addressCountry: "MX",
	},
	priceRange: "$$",
	telephone: `+${phoneNumber}`,
});

const faqSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
});
---

<Layout
	title="Reparación Google Pixel en Monterrey | Especialistas Pixel Fix"
	description="Servicio técnico especializado para Google Pixel en Monterrey. Cambio de pantalla, batería y tapas originales con garantía directa local."
	image="https://www.pixelfixmexico.com/og-image-reparaciones.jpg"
	url="https://www.pixelfixmexico.com/reparacion-google-pixel-monterrey/"
>
	<script type="application/ld+json" set:html={localBusinessSchema} />
	<script type="application/ld+json" set:html={faqSchema} />

	<!-- Ambient background -->
	<div class="fixed inset-0 pointer-events-none z-[-1] bg-[#F3F3F1]">
		<div
			class="absolute inset-0 opacity-[0.03] animate-[pulse_20s_ease-in-out_infinite]"
			style="background: radial-gradient(circle at 50% 0%, #111111 0%, transparent 60%);"
		>
		</div>
	</div>

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section
			class="max-w-5xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center gap-12 reveal"
		>
			<div class="flex-1 flex flex-col items-start text-left">
				<h1
					class="mb-4 inline-flex items-center gap-2 px-3 py-1 bg-[#E1F3FE] text-[#1F6C9F] text-xs font-mono font-medium rounded-full tracking-wide uppercase"
				>
					Servicio Técnico Google Pixel en Monterrey
				</h1>
				<p
					class="font-serif-editorial text-5xl md:text-[5rem] font-medium tracking-[-0.03em] text-[#111111] leading-[1.05] mb-8"
				>
					Reparación de Google Pixel en Monterrey.
				</p>
				<p
					class="text-lg md:text-xl text-[#787774] mb-10 leading-[1.6] max-w-lg font-light"
				>
					Servicio técnico profesional de pantallas, baterías y tapas traseras
					originales. Garantía real local y envíos nacionales.
				</p>
				<a
					href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20cotizar%20la%20reparaci%C3%B3n%20de%20mi%20Google%20Pixel%20en%20Monterrey.`}
					target="_blank"
					rel="noopener noreferrer"
					data-umami-event="repairs_hero_whatsapp_click"
					class="group inline-flex items-center justify-center px-8 py-4 bg-[#111111] text-white text-sm font-medium rounded transition-transform hover:scale-[0.98]"
				>
					<span>Cotizar mi reparación por WhatsApp</span>
					<svg
						class="w-4 h-4 ml-3 opacity-70 group-hover:opacity-100 transition-opacity"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
					</svg>
				</a>
			</div>
			<div class="flex-1 w-full relative h-[400px] md:h-[500px]">
				<div
					class="absolute inset-0 bg-[#F9F9F8] border border-[#EAEAEA] rounded-xl overflow-hidden"
				>
					<img
						src="/hero-repair.jpg"
						alt="Laboratorio de reparación Google Pixel"
						fetchpriority="high"
						loading="eager"
						class="w-full h-full object-cover opacity-90 saturate-50 contrast-125 mix-blend-multiply"
					/>
					<div class="absolute inset-0 bg-[#111111] opacity-[0.02]"></div>
				</div>
			</div>
		</section>

		<!-- Selector de Modelos y Precios -->
		<section
			id="cotizador"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-12 max-w-2xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Catálogo de Reparaciones.
				</h2>
				<p class="text-[#787774] leading-[1.6] mb-4">
					Cotiza la refacción original o OEM que requieres con o sin instalación
					en Monterrey.
				</p>
				<div
					class="inline-flex items-center px-3 py-1.5 bg-[#F9F9F8] border border-[#EAEAEA] rounded font-mono text-xs text-[#111111] mb-2"
				>
					<span class="w-1.5 h-1.5 rounded-full bg-[#111111] mr-2"></span>
					Piezas oficiales importadas. Garantía directa sin intermediarios.
				</div>
			</div>

			<!-- Selector de Series -->
			<div class="flex justify-center mb-10 w-full max-w-xs mx-auto">
				<div class="relative w-full">
					<select 
						id="model-select" 
						data-umami-event="repairs_select_changed"
						class="w-full bg-white border border-[#EAEAEA] rounded-lg px-4 py-3 text-sm font-medium text-[#111111] appearance-none cursor-pointer focus:outline-none focus:ring-1 focus:ring-[#111111] focus:border-[#111111] transition-all shadow-[0_2px_8px_rgba(0,0,0,0.02)]"
					>
						{repairCatalog.map((catalog, index) => (
							<option value={catalog.id} selected={index === 2}>
								{catalog.series}
							</option>
						))}
					</select>
					<div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-[#787774]">
						<svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
							<path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
						</svg>
					</div>
				</div>
			</div>

			<!-- Tab Contents -->
			<div class="relative min-h-[300px]">
				{
					repairCatalog.map((catalog, index) => (
						<div
							class={`tab-content grid grid-cols-1 md:grid-cols-2 gap-6 ${index === 2 ? "" : "hidden"}`}
							id={catalog.id}
						>
							{catalog.parts.map((part) => (
								<div class="bg-[#FFFFFF] p-6 border border-[#EAEAEA] rounded-xl flex flex-col justify-between transition-all hover:shadow-[0_4px_12px_rgba(0,0,0,0.03)] hover:border-[#CCCCCC]">
									<div>
										<div class="flex items-center justify-between gap-2 mb-4 border-b border-[#F3F3F1] pb-3">
											<span class="text-xs font-mono font-medium text-[#111111] bg-[#F9F9F8] border border-[#EAEAEA] px-2 py-0.5 rounded-full">{part.model}</span>
											<span class="text-xs font-mono text-[#956400] bg-[#FBF3DB] px-2 py-0.5 rounded">{part.delivery}</span>
										</div>
										<h3 class="text-lg font-semibold text-[#111111] leading-snug mb-4">
											{part.name}
										</h3>
										
										<div class="space-y-3 text-sm text-[#787774] mb-6">
											<div class="flex justify-between border-b border-[#F3F3F1]/50 pb-2">
												<span>Refacción sola:</span>
												<span class="font-medium text-[#111111] font-mono">
													{formatPrice(part.pricePart, part.ganancia)}
												</span>
											</div>
											<div class="flex justify-between pb-1">
												<span>Con instalación en MTY:</span>
												<span class="font-medium text-[#111111] font-mono">
													{formatPrice(part.priceInstall, part.ganancia)}
												</span>
											</div>
										</div>
									</div>
									
									<a
										href="#"
										data-msg={`Hola Pixel Fix, quiero solicitar reparación de ${part.name} para mi ${part.model} en Monterrey.`}
										data-umami-event="repairs_cotizar_click"
										data-umami-event-model={part.model}
										data-umami-event-part={part.name}
										class="wa-link block w-full text-center py-3 bg-[#111111] hover:bg-[#222222] text-white text-xs font-mono font-medium rounded transition-transform hover:scale-[0.98]"
									>
										Solicitar Cita
									</a>
								</div>
							))}
						</div>
					))
				}
			</div>
		</section>

		<!-- Enlace contextual a ventas -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow">
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-[#111111] mb-2">¿Prefieres renovar tu dispositivo?</h3>
					<p class="text-sm text-[#787774] leading-[1.6]">
						Si la reparación no es viable o prefieres actualizar tu teléfono, contamos con un catálogo curado de <a href="/venta-google-pixel-monterrey" data-umami-event="repairs_contextual_sales_link_click" class="text-[#111111] underline hover:text-[#1F6C9F] transition-colors">celulares Google Pixel Usados Estética 9 y Open Box</a> con garantía local directa.
					</p>
				</div>
				<a href="/venta-google-pixel-monterrey" data-umami-event="repairs_go_to_sales_click" class="px-6 py-3.5 bg-[#111111] text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0">
					Ver Equipos en Venta
				</a>
			</div>
		</section>

		<!-- El Proceso de Confianza & Logística -->
		<section
			id="proceso"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-16 max-w-xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Proceso de Servicio.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Repara tu dispositivo de manera transparente y con técnicos
					capacitados.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6">
				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						01
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Envías o Agendas
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Nos contactas por WhatsApp para agendar tu cita física en Monterrey
						o coordinar envío por paquetería.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						02
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Diagnóstico y Reparación
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Instalamos las refacciones originales o calidad OEM seleccionadas
						bajo estrictos controles técnicos.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						03
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Garantía Directa
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Te devolvemos tu Google Pixel reparado con sello de garantía local
						en Monterrey.
					</p>
				</div>
			</div>
		</section>

		<!-- Garantía de Origen y Soporte de Google -->
		<section id="garantia-soporte" class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal">
			<div class="mb-16 max-w-2xl">
				<h2 class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4">
					Piezas Genuinas y Garantía Oficial de Fábrica.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Nos aseguramos de que tu Google Pixel mantenga su integridad técnica y la cobertura de fábrica.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8 mb-12">
				<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col justify-between hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow">
					<div>
						<div class="inline-flex items-center gap-2 px-3 py-1 bg-[#E8F5E9] text-[#2E7D32] text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-6">
							Refacciones 100% Originales
						</div>
						<h3 class="text-xl font-medium text-[#111111] mb-4">iFixit y Distribuidores OEM en USA</h3>
						<p class="text-sm text-[#787774] leading-[1.7] mb-6">
							Todas nuestras refacciones son originales autorizadas por Google, importadas directamente desde **iFixit** y otros distribuidores de alta calidad en EE. UU. (OEM). Esto nos permite ofrecer soporte técnico oficial con el estándar de calidad del fabricante, garantizando la perfecta calibración de pantalla y biometría en tu Google Pixel.
						</p>
					</div>
					<div class="text-xs font-mono text-[#787774]">
						Soporte Técnico Especializado • Componentes Genuinos
					</div>
				</div>

				<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col justify-between hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow">
					<div>
						<div class="inline-flex items-center gap-2 px-3 py-1 bg-[#E1F3FE] text-[#1F6C9F] text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-6">
							Garantía Directa de Google
						</div>
						<h3 class="text-xl font-medium text-[#111111] mb-4">Gestión de Garantía con el Fabricante</h3>
						<p class="text-sm text-[#787774] leading-[1.7] mb-6">
							¿Tu dispositivo aún tiene garantía vigente directa con Google y prefieres repararlo con ellos? Nosotros nos encargamos de todo. Realizamos el diagnóstico y **gestionamos el envío de tu equipo a garantía directo con Google en USA**, facilitándote todo el proceso logístico internacional y de aduanas.
						</p>
					</div>
					<div class="text-xs font-mono text-[#787774]">
						Trámite Logístico Seguro • Cobertura Google USA
					</div>
				</div>
			</div>

			<!-- Flujo detallado del trámite de garantía -->
			<div class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl">
				<h3 class="text-lg font-medium text-[#111111] mb-6">¿Cómo gestionamos tu garantía con Google desde México?</h3>
				<div class="grid sm:grid-cols-3 gap-8">
					<div>
						<span class="text-xs font-mono text-[#1F6C9F] block mb-2">Paso 01</span>
						<h4 class="text-sm font-medium text-[#111111] mb-2">Diagnóstico de Calificación</h4>
                        <p class="text-xs text-[#787774] leading-[1.6]">
                            Evaluamos físicamente tu Pixel para descartar daños accidentales (pantallas rotas, humedad o golpes) que anulen la garantía de Google. Si califica, procedemos con el trámite.
                        </p>
					</div>
					<div>
						<span class="text-xs font-mono text-[#1F6C9F] block mb-2">Paso 02</span>
						<h4 class="text-sm font-medium text-[#111111] mb-2">Logística Fronteriza y Envío</h4>
                        <p class="text-xs text-[#787774] leading-[1.6]">
                            Trasladamos de forma segura tu equipo a nuestras oficinas de importación en EE. UU., activamos la orden de soporte con Google y lo enviamos directamente a su centro de servicio técnico oficial.
                        </p>
					</div>
					<div>
						<span class="text-xs font-mono text-[#1F6C9F] block mb-2">Paso 03</span>
						<h4 class="text-sm font-medium text-[#111111] mb-2">Importación y Entrega</h4>
                        <p class="text-xs text-[#787774] leading-[1.6]">
                            Una vez que Google repara o reemplaza el dispositivo bajo garantía, lo recibimos en USA, gestionamos la aduana y logística de retorno a México, y te lo entregamos en Monterrey o lo enviamos a tu domicilio.
                        </p>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimoniales (Abstraído) -->
		<Testimonials />

		<!-- Dudas Frecuentes -->
		<section
			id="faq"
			class="max-w-3xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-12">
				<h2
					class="font-serif-editorial text-3xl tracking-tight text-[#111111] mb-4"
				>
					Dudas Frecuentes.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Respuestas sobre el servicio técnico y garantía local.
				</p>
			</div>

			<div class="space-y-6">
				{
					faqs.map((faq) => (
						<div class="pb-6 border-b border-[#EAEAEA]">
							<h3 class="text-lg font-medium text-[#111111] mb-3">
								{faq.question}
							</h3>
							<p class="text-[#787774] text-sm leading-[1.6]">{faq.answer}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<script>
	// Model Selector Logic
	const modelSelect = document.getElementById("model-select");
	const contents = document.querySelectorAll(".tab-content");

	if (modelSelect) {
		modelSelect.addEventListener("change", (e) => {
			const targetId = (e.target as HTMLSelectElement).value;
			contents.forEach((c) => c.classList.add("hidden"));
			const targetEl = document.getElementById(targetId);
			if (targetEl) targetEl.classList.remove("hidden");
		});
	}

	// WhatsApp Links Builder
	const PHONE_NUMBER = "528111913676";
	const waLinks = document.querySelectorAll(".wa-link");

	waLinks.forEach((link) => {
		const msg = link.getAttribute("data-msg");
		if (msg) {
			link.setAttribute(
				"href",
				`https://wa.me/${PHONE_NUMBER}?text=${encodeURIComponent(msg)}`,
			);
			link.setAttribute("target", "_blank");
			link.setAttribute("rel", "noopener noreferrer");
		}
	});

	// Scroll Reveal
	const observer = new IntersectionObserver(
		(entries, obs) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("revealed");
					obs.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1 },
	);

	document.querySelectorAll(".reveal").forEach((el) => {
		observer.observe(el);
	});
</script>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
			transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}
</style>
