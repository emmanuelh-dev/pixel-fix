---
import Layout from "../layouts/Layout.astro";
import Testimonials from "../components/Testimonials.astro";
import { repairCatalog, formatPrice } from "../data/catalog";

function splitModels(raw: string): string[] {
	if (!raw.includes("/")) return [raw.trim()];
	return raw.split("/").map((m) => {
		m = m.trim();
		return m.startsWith("Pixel") ? m : `Pixel ${m}`;
	});
}

const MODEL_ORDER = [
	"Pixel 10 Pro XL",
	"Pixel 10 Pro",
	"Pixel 10",
	"Pixel 10a",
	"Pixel 9 Pro XL",
	"Pixel 9 Pro",
	"Pixel 9",
	"Pixel 9a",
	"Pixel 8 Pro",
	"Pixel 8",
	"Pixel 8a",
	"Pixel 7 Pro",
	"Pixel 7",
	"Pixel 7a",
	"Pixel 6 Pro",
	"Pixel 6",
	"Pixel 6a",
	"Pixel 5",
	"Pixel 5a",
];

// Normalizar catálogo de reparación (una tarjeta por modelo individual)
const repairParts = repairCatalog.flatMap((series) =>
	series.parts.flatMap((p) => {
		const isBateria = p.name.toLowerCase().includes("pila");
		const isOriginal = p.name.toLowerCase().includes("original");
		const qualityTag = isOriginal ? "original" : "replica-excelente";
		const rawSlug = p.model
			.toLowerCase()
			.replace(/\s*\/\s*/g, "-")
			.replace(/\s+/g, "-")
			.replace(/[^a-z0-9-]/g, "");
		return splitModels(p.model).map((model) => ({
			id: `${series.id}-${model.toLowerCase().replace(/\s+/g, "-")}-${isBateria ? "bat" : "pan"}-${qualityTag}`,
			type: isBateria ? "Batería" : "Pantalla",
			model,
			name: p.name,
			pricePart: p.pricePart,
			priceInstall: p.priceInstall,
			delivery: p.delivery,
			wa: `Hola Pixel Fix, quiero solicitar reparación de ${p.name} para mi ${model} en Monterrey.`,
		}));
	}),
);

const availableModels = MODEL_ORDER.filter((m) =>
	repairParts.some((p) => p.model === m),
);

const faqs = [
	{
		question: "¿Cuánto cuesta reparar la pantalla del Pixel 8 en México?",
		answer:
			"El cambio de pantalla OLED de excelente calidad réplica (con sensor de huellas activo) para la línea Pixel 8 tiene un costo de $2,900 MXN la refacción sola, o $3,700 MXN instalada. El tiempo de entrega de importación oficial es de 10-12 días hábiles.",
	},
	{
		question: "¿Dónde puedo cambiar la batería de un Google Pixel?",
		answer:
			"En Pixel Fix realizamos el cambio de pila original nueva. Para las series Pixel 6 y 7, el costo es de $1,400 MXN la refacción sola o $2,200 MXN con instalación especializada. Las pilas originales de la serie 8 cuestan $1,600 MXN ($2,400 MXN instalada). El tiempo de importación es de 10-12 días hábiles.",
	},
	{
		question: "¿Qué garantía tienen las reparaciones y refacciones de Pixel?",
		answer:
			"Cualquier compra de refacciones o reparación instalada cuenta únicamente con **28 días de garantía** directa local en Monterrey. Transcurrido este plazo de 28 días, no se aceptan devoluciones ni cambios bajo ninguna circunstancia.",
	},
	{
		question:
			"¿Las refacciones de Google Pixel son originales y de dónde provienen?",
		answer:
			"Nuestras baterías son pilas originales nuevas de fábrica. Las pantallas son paneles OLED con lector de huella activo de calidad réplica excelente importadas de distribuidores en USA. Esto garantiza el óptimo desempeño del equipo a costos competitivos.",
	},
	{
		question:
			"¿Cómo funciona el trámite de garantía con Google si estoy en México?",
		answer:
			"Gestionamos la logística de envío de tu Pixel a soporte oficial de Google en USA para versiones americanas/globales (fallas de hardware de fábrica, no accidentes), verificando tu IMEI. El costo de gestión del trámite depende del caso: fallas de pantalla en Pixel 8 ($3,300 MXN) o Pixel 9 Pro/XL ($4,000 MXN); pila inflada de Pixel 7a ($2,500 MXN); cambio de Pixel 9 Pro Fold a la Serie 10 ($6,000 a $10,500 MXN); o la gestión general de garantías vigentes de la Serie 9 ($2,500 MXN) o Serie 10 ($3,000 MXN).",
	},
];

const phoneNumber = "528111913676";

// Generar LD+JSON Scripts estáticos para Astro
const localBusinessSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	name: "Pixel Fix México",
	image: "https://www.pixelfixmexico.com/logo.png",
	description:
		"Especialistas en Reparación de Google Pixel en Monterrey. Pantallas, tapas y baterías originales.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Monterrey",
		addressRegion: "NL",
		addressCountry: "MX",
	},
	priceRange: "$$",
	telephone: `+${phoneNumber}`,
});

const faqSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
});
---

<Layout
	title="Reparación Google Pixel en Monterrey | Especialistas Pixel Fix"
	description="Servicio técnico especializado para Google Pixel en Monterrey. Cambio de pantalla, batería y tapas originales con garantía directa local."
	image="https://www.pixelfixmexico.com/og-image-reparaciones.jpg"
	url="https://www.pixelfixmexico.com/reparacion-google-pixel-monterrey/"
>
	<script type="application/ld+json" set:html={localBusinessSchema} />
	<script type="application/ld+json" set:html={faqSchema} />

	<main class="min-h-screen">
		<!-- Hero compacto: copy + trust pills, sin imagen que robe viewport -->
		<section class="max-w-5xl mx-auto px-6 pt-10 pb-6">
			<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
				<div class="max-w-xl">
					<span class="inline-flex items-center gap-2 px-3 py-1 bg-[#E1F3FE] text-[#1F6C9F] text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-4">
						Especialistas Google Pixel · Monterrey
					</span>
					<h1 class="text-4xl md:text-5xl font-medium tracking-tight text-[#111111] leading-[1.05] mb-3">
						Reparación Google Pixel<br/>en Monterrey.
					</h1>
					<p class="text-base text-[#787774] leading-relaxed max-w-md">
						Pantallas, baterías y tapas originales. Garantía local directa. Envío a todo México.
					</p>
				</div>
				<!-- Trust pills verticales en desktop -->
				<div class="flex flex-row md:flex-col gap-2 flex-wrap">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#EDF3EC] border border-[#C3E0C5] rounded-lg text-xs text-[#346538] font-mono">
						<span class="w-1.5 h-1.5 rounded-full bg-[#346538] flex-shrink-0"></span>
						Combo: Pantalla + Pila — instalación $800 MXN
					</div>
					<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#F9F9F8] border border-[#EAEAEA] rounded-lg text-xs text-[#787774] font-mono">
						<span class="w-1.5 h-1.5 rounded-full bg-[#111111] flex-shrink-0"></span>
						28 días garantía · Envío $250 MXN
					</div>
					<a
						href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20quisiera%20cotizar%20la%20reparaci%C3%B3n%20de%20mi%20Google%20Pixel%20en%20Monterrey.`}
						target="_blank" rel="noopener noreferrer"
						data-umami-event="repairs_hero_whatsapp_click"
						class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-[#25D366] text-white text-xs font-medium rounded-lg hover:bg-[#1ebe5d] transition-colors whitespace-nowrap"
					>
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
						Cotizar por WhatsApp
					</a>
				</div>
			</div>
		</section>

		<!-- Catálogo: inmediatamente visible, sin padding superior generoso -->
		<section
			id="cotizador"
			class="max-w-5xl mx-auto px-6 pb-16 border-t border-[#EAEAEA] pt-8"
		>
			<!-- Chips Tipo -->
			<div class="mb-2">
				<p class="text-[10px] font-mono uppercase tracking-wider text-[#ADADAD] mb-2">Tipo</p>
				<div id="rep-type-filters" class="flex flex-wrap gap-2">
					<button data-type="all" class="rep-type-btn r-chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all">Todo</button>
					<button data-type="Pantalla" class="rep-type-btn r-chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all flex items-center gap-1.5">
						<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
						Pantalla
					</button>
					<button data-type="Batería" class="rep-type-btn r-chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all flex items-center gap-1.5">
						<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M22 11v2"/></svg>
						Batería
					</button>
				</div>
			</div>

			<!-- Chips Modelo -->
			<div class="mb-6">
				<p class="text-[10px] font-mono uppercase tracking-wider text-[#ADADAD] mb-2">Modelo</p>
				<div id="rep-model-filters" class="flex flex-wrap gap-2">
					<button data-model="all" class="rep-model-btn r-chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all">Todos</button>
					{availableModels.map(m => (
						<button data-model={m} class="rep-model-btn r-chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all">{m}</button>
					))}
				</div>
			</div>

			<!-- Contador -->
			<p id="rep-count" class="text-xs font-mono text-[#ADADAD] mb-4">{repairParts.length} piezas</p>

			<!-- Grid reparaciones -->
			<div id="rep-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
				{repairParts.map(part => (
					<div class="rep-card bg-[#FFFFFF] border border-[#EAEAEA] rounded-xl flex flex-col transition-all hover:shadow-[0_4px_12px_rgba(0,0,0,0.04)] hover:border-[#CCCCCC]"
						data-type={part.type} data-model={part.model}>
						<!-- Header coloreado según tipo -->
						<div class={`px-4 pt-4 pb-3 border-b border-[#F3F3F1] flex items-center justify-between gap-2`}>
							<div class="flex items-center gap-2">
								<!-- tipo icon -->
								{part.type === 'Pantalla' ? (
									<svg class="w-3.5 h-3.5 text-[#1F6C9F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
								) : (
									<svg class="w-3.5 h-3.5 text-[#346538]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M22 11v2"/></svg>
								)}
								<span class="text-xs font-mono font-medium text-[#787774]">{part.type}</span>
							</div>
							<span class="text-[10px] font-mono text-[#956400] bg-[#FBF3DB] px-2 py-0.5 rounded">{part.delivery}</span>
						</div>
						<!-- Body -->
						<div class="px-4 py-3 flex-1">
							<p class="text-xs font-mono font-medium text-[#111111] bg-[#F9F9F8] border border-[#EAEAEA] px-2 py-0.5 rounded-full inline-block mb-2">{part.model}</p>
							<p class="text-sm font-medium text-[#787774] leading-snug mb-3">{part.name}</p>
							<!-- Precios prominentes -->
							<div class="space-y-1">
								<div class="flex items-baseline justify-between">
									<span class="text-[11px] text-[#ADADAD]">Refacción</span>
									<span class="text-base font-bold text-[#111111] font-mono">{formatPrice(part.pricePart)}</span>
								</div>
								{part.priceInstall > 0 && (
									<div class="flex items-baseline justify-between">
										<span class="text-[11px] text-[#ADADAD]">+ Instalación MTY</span>
										<span class="text-sm font-semibold text-[#111111] font-mono">{formatPrice(part.priceInstall)}</span>
									</div>
								)}
							</div>
						</div>
						<!-- Acciones -->
						<div class="px-4 pb-4 flex gap-2">
							<a href={`https://wa.me/${phoneNumber}?text=${encodeURIComponent(part.wa)}`} target="_blank" rel="noopener noreferrer"
								data-umami-event="repairs_cotizar_click"
								class="flex-1 text-center py-2 border border-[#EAEAEA] text-[#787774] text-xs font-mono rounded-lg hover:border-[#111111] hover:text-[#111111] transition-all">
								Solicitar cita
							</a>
							<button data-id={part.id} data-name={part.model} data-part={part.name} data-price={part.pricePart}
								class="add-btn flex-1 flex items-center justify-center gap-1.5 py-2 bg-[#111111] text-white text-xs font-medium rounded-lg hover:bg-[#333] transition-colors">
								<svg class="w-3.5 h-3.5 btn-icon-cart" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
								</svg>
								<svg class="w-3.5 h-3.5 btn-icon-check hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
									<polyline points="20 6 9 17 4 12"/>
								</svg>
								<span class="btn-label">Agregar</span>
							</button>
						</div>
					</div>
				))}
			</div>

			<div id="rep-no-results" class="hidden py-12 text-center text-[#ADADAD] text-sm">Sin resultados para ese filtro.</div>
		</section>

		<!-- Enlace contextual a ventas -->
		<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
			<div
				class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
			>
				<div class="max-w-xl">
					<h3 class="text-lg font-medium text-[#111111] mb-2">
						¿Prefieres renovar tu dispositivo?
					</h3>
					<p class="text-sm text-[#787774] leading-[1.6]">
						Si la reparación no es viable o prefieres actualizar tu teléfono,
						contamos con un catálogo curado de <a
							href="/venta-google-pixel-monterrey"
							data-umami-event="repairs_contextual_sales_link_click"
							class="text-[#111111] underline hover:text-[#1F6C9F] transition-colors"
							>celulares Google Pixel Usados Estética 9 y Open Box</a
						> con garantía local directa.
					</p>
				</div>
				<a
					href="/venta-google-pixel-monterrey"
					data-umami-event="repairs_go_to_sales_click"
					class="px-6 py-3.5 bg-[#111111] text-white text-xs font-mono font-medium rounded hover:scale-[0.98] transition-all shrink-0"
				>
					Ver Equipos en Venta
				</a>
			</div>
		</section>

		<!-- El Proceso de Confianza & Logística -->
		<section
			id="proceso"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-16 max-w-xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Proceso de Servicio.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Repara tu dispositivo de manera transparente y con técnicos
					capacitados.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6">
				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						01
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Envías o Agendas
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Nos contactas por WhatsApp para agendar tu cita física en Monterrey
						o coordinar envío por paquetería.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						02
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Diagnóstico y Reparación
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Instalamos las refacciones originales o calidad OEM seleccionadas
						bajo estrictos controles técnicos.
					</p>
				</div>

				<div
					class="bg-[#F9F9F8] border border-[#EAEAEA] p-8 rounded-xl flex flex-col"
				>
					<div
						class="text-[#787774] font-mono text-xs mb-4 border border-[#EAEAEA] bg-white w-8 h-8 flex items-center justify-center rounded"
					>
						03
					</div>
					<h3 class="text-base font-medium text-[#111111] mb-2">
						Garantía Directa
					</h3>
					<p class="text-[#787774] text-sm leading-[1.6]">
						Te devolvemos tu Google Pixel reparado con sello de garantía local
						en Monterrey.
					</p>
				</div>
			</div>
		</section>

		<!-- Garantía de Origen y Soporte de Google -->
		<section
			id="garantia-soporte"
			class="max-w-5xl mx-auto px-6 py-24 border-t border-[#EAEAEA] reveal"
		>
			<div class="mb-16 max-w-2xl">
				<h2
					class="font-serif-editorial text-3xl md:text-4xl tracking-tight text-[#111111] mb-4"
				>
					Piezas Genuinas y Garantía Oficial de Fábrica.
				</h2>
				<p class="text-[#787774] leading-[1.6]">
					Nos aseguramos de que tu Google Pixel mantenga su integridad técnica y
					la cobertura de fábrica.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8 mb-12">
				<div
					class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col justify-between hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
				>
					<div>
						<div
							class="inline-flex items-center gap-2 px-3 py-1 bg-[#E8F5E9] text-[#2E7D32] text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-6"
						>
							Refacciones 100% Originales
						</div>
						<h3 class="text-xl font-medium text-[#111111] mb-4">
							iFixit y Distribuidores OEM en USA
						</h3>
						<p class="text-sm text-[#787774] leading-[1.7] mb-6">
							Todas nuestras refacciones son originales autorizadas por Google,
							importadas directamente desde **iFixit** y otros distribuidores de
							alta calidad en EE. UU. (OEM). Esto nos permite ofrecer soporte
							técnico oficial con el estándar de calidad del fabricante,
							garantizando la perfecta calibración de pantalla y biometría en tu
							Google Pixel.
						</p>
					</div>
					<div class="text-xs font-mono text-[#787774]">
						Soporte Técnico Especializado • Componentes Genuinos
					</div>
				</div>

				<div
					class="bg-[#FFFFFF] p-8 border border-[#EAEAEA] rounded-xl flex flex-col justify-between hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] transition-shadow"
				>
					<div>
						<div
							class="inline-flex items-center gap-2 px-3 py-1 bg-[#E1F3FE] text-[#1F6C9F] text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-6"
						>
							Garantía Directa de Google
						</div>
						<h3 class="text-xl font-medium text-[#111111] mb-4">
							Gestión de Garantía con el Fabricante
						</h3>
