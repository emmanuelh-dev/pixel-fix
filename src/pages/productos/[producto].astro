---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import { repairCatalog, formatPrice } from '../../data/catalog';
import { phoneNumber } from '../../data/store';
import { productSchema, breadcrumbSchema, faqSchema } from '../../lib/seo';

export function getStaticPaths() {
  const paths: { params: { producto: string }; props: any }[] = [];

  for (const series of repairCatalog) {
    for (const part of series.parts) {
      const isBateria = part.name.toLowerCase().includes('pila');
      const partType = isBateria ? 'bateria' : 'pantalla';
      const isOriginal = part.name.toLowerCase().includes('original');
      const qualityTag = isOriginal ? 'original' : 'replica-excelente';
      const modelSlug = part.model
        .toLowerCase()
        .replace(/\s*\/\s*/g, '-')
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '');
      const slug = `${partType}-${modelSlug}-${qualityTag}`;

      const existing = paths.find(p => p.params.producto === slug);
      if (!existing) {
        paths.push({
          params: { producto: slug },
          props: { slug, isBateria, isOriginal, model: part.model, series: series.series, seriesId: series.id, parts: [part] },
        });
      } else {
        existing.props.parts.push(part);
      }
    }
  }

  return paths;
}

const { isBateria, isOriginal, model, series, parts, seriesId } = Astro.props;
const { producto } = Astro.params;

const partLabel = isBateria ? 'Batería' : 'Pantalla';
const qualityLabel = isOriginal ? 'Original' : 'Réplica Excelente';
const modelDisplay = model.replace(/\//g, 'y');

const title = `${partLabel} Google ${modelDisplay} ${qualityLabel} en México | Pixel Fix — Alternativa iFixit`;
const description = `Compra la ${partLabel.toLowerCase()} ${qualityLabel.toLowerCase()} para tu Google ${modelDisplay} en México. Envío nacional en ${parts[0]?.delivery}. Precio desde ${formatPrice(Math.min(...parts.map((p: any) => p.pricePart)))}. iFixit no envía a México — nosotros sí.`;

const pageUrl = `https://www.pixelfixmexico.com/productos/${producto}/`;

const productImage = `/images/productos/${producto}.webp`;

const faqs = [
  {
    question: `¿Puedo comprar la ${partLabel.toLowerCase()} del ${model} en México?`,
    answer: `Sí. En Pixel Fix importamos la ${partLabel.toLowerCase()} directamente desde distribuidores OEM en USA y la enviamos a todo México. El tiempo de entrega es de ${parts[0]?.delivery}.`,
  },
  {
    question: `¿iFixit envía ${partLabel.toLowerCase()}s de Google Pixel a México?`,
    answer: `iFixit es un referente mundial en refacciones originales de Google Pixel, pero actualmente no tiene envíos directos a México. Pixel Fix importa piezas de la misma cadena de distribución y las entrega en territorio nacional.`,
  },
  {
    question: `¿La ${partLabel.toLowerCase()} ${qualityLabel.toLowerCase()} funciona igual que la original?`,
    answer: isBateria
      ? `Sí. Las baterías originales son idénticas a las de fábrica en capacidad y voltaje. Las réplica excelente tienen rendimiento equivalente al 95% de la original.`
      : `La pantalla incluye el sensor de huella dactilar integrado y funciona con todas las características del sistema. La calidad ${qualityLabel.toLowerCase()} es la mejor disponible en el mercado para esta pantalla.`,
  },
  {
    question: `¿Cuánto cuesta enviar la ${partLabel.toLowerCase()} a mi ciudad?`,
    answer: `El envío tiene un costo fijo de $250 MXN a cualquier parte de México, sin importar la cantidad de piezas que pidas en el mismo paquete.`,
  },
];

const itemSchema = productSchema({
  name: `${partLabel} Google ${modelDisplay} ${qualityLabel}`,
  description,
  image: `https://www.pixelfixmexico.com${productImage}`,
  offers: parts.map((p: any) => ({ price: p.pricePart, name: p.model })),
});

const crumbSchema = breadcrumbSchema([
  { name: "Inicio", url: "https://www.pixelfixmexico.com/" },
  { name: "Tienda", url: "https://www.pixelfixmexico.com/tienda/" },
  { name: `${partLabel} ${model}`, url: pageUrl },
]);

const questionsSchema = faqSchema(faqs);
---

<Layout title={title} description={description} url={pageUrl}>
  <script type="application/ld+json" set:html={itemSchema} />
  <script type="application/ld+json" set:html={crumbSchema} />
  <script type="application/ld+json" set:html={questionsSchema} />

  <main class="min-h-screen max-w-4xl mx-auto px-4 py-12 md:py-20">

    <!-- Breadcrumb -->
    <nav class="text-xs font-mono text-muted-strong mb-8 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-ink transition-colors">Inicio</a>
      <span>/</span>
      <a href="/tienda" class="hover:text-ink transition-colors">Tienda</a>
      <span>/</span>
      <span class="text-ink font-medium">{partLabel} {model}</span>
    </nav>

    <!-- Grid de contenido adaptado para móviles -->
    <div class="flex flex-col md:grid md:grid-cols-2 md:gap-12 items-start">

      <!-- Imagen: Siempre arriba en móviles -->
      <div class="w-full order-1 md:order-none mb-6 md:mb-0">
        <div class="relative w-full aspect-square bg-surface-muted border border-border-strong rounded-2xl overflow-hidden flex items-center justify-center group">
          <img 
            src={productImage} 
            alt={`${partLabel} Google ${modelDisplay} ${qualityLabel}`}
            class="w-full h-full object-contain p-6 group-hover:scale-105 transition-transform duration-300"
            loading="eager"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="hidden absolute inset-0 flex-col items-center justify-center text-muted-strong gap-2 select-none">
            <Icon name={isBateria ? "ph:battery-charging-vertical" : "ph:rectangle"} class="w-12 h-12" />
            <span class="text-[10px] font-mono uppercase tracking-wider">Refacción Google Pixel</span>
          </div>
        </div>
      </div>

      <!-- Info Principal -->
      <div class="w-full order-2 md:order-none mb-6 md:mb-0">
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-accent-soft text-accent text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-4">
          {partLabel} · {series}
        </span>

        <h1 class="text-2xl md:text-4xl font-semibold tracking-tight text-ink leading-tight mb-3">
          {partLabel} Google {modelDisplay}
          <span class="block text-base md:text-lg font-normal text-muted-strong mt-1">{qualityLabel} — disponible en México</span>
        </h1>

        <p class="text-sm md:text-base text-muted-strong leading-relaxed mb-6">
          {isBateria
            ? `Batería ${qualityLabel.toLowerCase()} para ${model}. Capacidad y voltaje originales de fábrica. Compatible con todas las funciones del sistema, incluyendo indicador de porcentaje preciso.`
            : `Pantalla ${qualityLabel.toLowerCase()} con sensor de huella dactilar integrado para ${model}. Compatible al 100% con las funciones táctiles y de reconocimiento biométrico del equipo.`
          }
        </p>
      </div>

      <!-- Nuevo visual de Precios, Variantes y Botones -->
      <div id="product-variants-container" class="w-full order-3 md:order-none mb-8 md:mb-0 space-y-6">
        <h2 class="text-xs font-mono uppercase tracking-wider text-muted-strong border-b border-border pb-2">Precios y opciones de compra</h2>
        
        {parts.map((part: any, index: number) => {
          const qualityTag = isOriginal ? 'original' : 'replica-excelente';
          const generatedId = `${seriesId}-${part.model.toLowerCase().replace(/\s+/g, '-')}-${isBateria ? 'bat' : 'pan'}-${qualityTag}`;
          const waMsg = encodeURIComponent(`Hola, quiero comprar la ${part.name} para mi ${part.model} por ${formatPrice(part.pricePart)}. ¿Tienen disponibilidad?`);

          return (
            <div class={`pb-6 ${index !== parts.length - 1 ? 'border-b border-border' : ''}`}>
              <div class="flex flex-col gap-1 mb-3">
                <span class="text-xs font-mono text-muted-strong">{part.model}</span>
                <span class="text-base font-medium text-ink">{part.name}</span>
              </div>

              <!-- Desglose de costos limpio -->
              <div class="space-y-1.5 mb-4 text-sm text-muted-strong">
                <div class="flex justify-between items-baseline">
                  <span>Solo pieza:</span>
                  <span class="font-mono font-bold text-ink text-lg">{formatPrice(part.pricePart)}</span>
                </div>
                {part.priceInstall > 0 && (
                  <div class="flex justify-between items-baseline text-xs text-muted-strong">
                    <span>Con instalación en MTY:</span>
                    <span class="font-mono">+{formatPrice(part.priceInstall)}</span>
                  </div>
                )}
                <div class="flex items-center gap-1.5 text-[11px] text-muted-strong pt-1">
                  <Icon name="ph:truck" class="w-3.5 h-3.5" />
                  <span>{part.delivery}</span>
                </div>
              </div>

              <!-- Bloque de botones en una sola fila minimalista -->
              <div class="flex items-stretch gap-2">
                <a
                  href={`https://wa.me/${phoneNumber}?text=${waMsg}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2.5 text-xs font-mono border border-border-strong text-muted-strong rounded-lg hover:border-ink hover:text-ink transition-all whitespace-nowrap flex items-center justify-center bg-white"
                >
                  Comprar
                </a>
                <button
                  data-id={generatedId}
                  data-name={part.model}
                  data-part={part.name}
                  data-price={part.pricePart}
                  class="add-btn flex-1 flex items-center justify-center gap-1.5 py-2.5 px-4 bg-ink text-white text-xs font-medium rounded-lg hover:bg-ink-hover transition-colors shadow-sm"
                >
                  <Icon name="ph:shopping-cart" class="w-3.5 h-3.5 btn-icon-cart" />
                  <Icon name="ph:check" class="w-3.5 h-3.5 btn-icon-check hidden" />
                  <span class="btn-label">Agregar al carrito</span>
                </button>
              </div>
            </div>
          );
        })}

        <div class="text-[11px] text-muted-strong leading-relaxed p-4 border border-border rounded-xl bg-surface-muted">
          <strong class="text-ink block mb-0.5">Garantía y devoluciones</strong>
          28 días de garantía directa en Monterrey. Transcurrido este plazo no se aceptan devoluciones ni cambios bajo ninguna circunstancia.
        </div>
      </div>

      <!-- Propuesta de Valor -->
      <div class="w-full order-4 md:order-none space-y-4 mb-4 md:mb-0">
        <div class="bg-bg rounded-xl p-5 space-y-3">
          <p class="text-xs font-mono uppercase tracking-wider text-muted-strong mb-1">¿Por qué Pixel Fix?</p>
          {[
            `Envío a todo México — iFixit no envía a México`,
            `Importación directa desde distribuidores OEM en USA`,
            `Garantía local de 28 días en Monterrey`,
            `Instalación disponible con técnicos certificados`,
            isOriginal ? `Pieza de fábrica Google / iFixit compatible` : `Calidad Réplica Excelente con huella activa`,
          ].map(point => (
            <div class="flex items-start gap-2.5">
              <Icon name="ph:check-circle" class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" />
              <span class="text-sm text-ink font-medium">{point}</span>
            </div>
          ))}
        </div>

        <a href="/tienda" class="flex items-center justify-center gap-2 w-full py-3 text-sm text-muted-strong hover:text-ink transition-colors border border-border-strong rounded-xl hover:border-ink bg-white">
          Ver todo el catálogo
        </a>
      </div>

    </div>

  </main>

  <Faq title="Preguntas frecuentes" items={faqs} />

  <script>
    document.getElementById("product-variants-container")?.addEventListener("click", (e) => {
      const btn = (e.target as Element).closest(".add-btn") as HTMLElement;
      if (!btn || !window.pfCart) return;
      
      window.pfCart.add(
        btn.dataset.id!,
        btn.dataset.name!,
        btn.dataset.part!,
        Number(btn.dataset.price),
      );
    });
  </script>
</Layout>