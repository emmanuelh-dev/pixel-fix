---
import Layout from '../layouts/Layout.astro';
import PaymentInfo from '../components/PaymentInfo.astro';
---

<Layout
  title="Mi perfil — Pixel Fix"
  description="Consulta todas tus órdenes y reparaciones en Pixel Fix Monterrey."
  url="https://www.pixelfixmexico.com/cliente"
>
  <main class="min-h-screen max-w-5xl mx-auto px-4 py-12 md:py-20">

    <nav class="text-xs font-mono text-muted-strong mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-ink transition-colors">Inicio</a>
      <span>/</span>
      <span class="text-ink font-medium">Mi perfil</span>
    </nav>

    <div class="max-w-2xl mx-auto">

      <div class="mb-10 text-center">
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-accent-soft text-accent text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-4">
          Mi perfil
        </span>
        <h1 id="cliente-title" class="text-4xl md:text-5xl font-medium tracking-tight text-ink leading-[1.05] mb-3">
          Tus órdenes y reparaciones
        </h1>
        <p class="text-base text-muted leading-relaxed">
          Aquí puedes ver todo tu historial con nosotros, en un solo lugar.
        </p>
      </div>

      <div id="cliente-result">
        <div class="rounded-xl border border-border bg-surface-muted p-6 text-center text-sm text-muted">Cargando…</div>
      </div>

      <div class="mt-8">
        <PaymentInfo />
      </div>

    </div>
  </main>
</Layout>

<script>
  const API = 'https://admin.bysmax.com/api';

  const STATUS_LABELS: Record<string, string> = {
    orden_recibida: 'Orden recibida',
    pago_confirmado: 'Pago confirmado',
    pedido_a_proveedor: 'Pedido a proveedor',
    en_bodega_usa: 'En bodega USA',
    enviado: 'Enviado',
    entregado: 'Entregado',
    esperando_dispositivo: 'Esperando dispositivo',
    dispositivo_recibido: 'Dispositivo recibido en taller',
    diagnostico: 'Diagnóstico',
    esperando_pieza: 'Esperando pieza',
    pieza_en_camino: 'Pieza en camino',
    en_reparacion: 'En reparación',
  };

  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

  function renderError(msg: string) {
    document.getElementById('cliente-result')!.innerHTML = `
      <div class="rounded-xl border border-danger-soft bg-danger-soft p-4 text-center text-sm text-danger">
        ${esc(msg)}
      </div>`;
  }

  function orderCard(o: any) {
    const isRepair = o.order_type === 'reparacion';
    const detailUrl = `/${isRepair ? 'reparaciones' : 'rastreo'}?id=${encodeURIComponent(o.code)}`;
    const updated = new Date(o.updated_at).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' });
    return `
      <a href="${detailUrl}" class="block rounded-2xl border border-border bg-surface p-5 hover:border-accent transition-colors">
        <div class="flex items-center justify-between gap-3 mb-2">
          <span class="font-mono text-lg font-bold text-ink">${esc((o.code || '').toUpperCase())}</span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-accent">${isRepair ? 'Reparación' : 'Envío'}</span>
        </div>
        ${o.description ? `<p class="text-sm text-muted-strong mb-3">${esc(o.description)}</p>` : ''}
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs font-medium text-ink">${esc(STATUS_LABELS[o.status] || o.status)}</span>
          <span class="text-[11px] text-faint">Actualizado: ${updated}</span>
        </div>
      </a>`;
  }

  async function load(id: string) {
    try {
      const res = await fetch(`${API}/customers/${encodeURIComponent(id)}/public`);
      if (!res.ok) { renderError('No encontramos ningún perfil con ese enlace.'); return; }
      const data = await res.json();
      if (data.customer?.name) {
        document.getElementById('cliente-title')!.textContent = `Hola, ${data.customer.name}`;
      }
      const resultEl = document.getElementById('cliente-result')!;
      resultEl.innerHTML = (data.orders && data.orders.length)
        ? `<div class="space-y-4">${data.orders.map(orderCard).join('')}</div>`
        : `<div class="rounded-xl border border-border bg-surface-muted p-6 text-center text-sm text-muted">Aún no tienes órdenes registradas.</div>`;
    } catch {
      renderError('Error de conexión. Intenta de nuevo.');
    }
  }

  const id = (new URLSearchParams(location.search).get('id') ?? '').trim();
  if (id) load(id); else renderError('Falta el identificador en el enlace. Pide tu liga de perfil por WhatsApp.');
</script>
