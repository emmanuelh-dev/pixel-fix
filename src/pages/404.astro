---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import { phoneNumber } from "../data/store";

const links = [
	{ href: "/tienda", label: "Tienda", description: "Catálogo completo de piezas y equipos" },
	{ href: "/reparacion-google-pixel-monterrey", label: "Reparación", description: "Servicio en Monterrey" },
	{ href: "/equipos", label: "Venta de Equipos", description: "Usados Estética 9 y Open Box" },
	{ href: "/piezas-originales-google-pixel-mexico", label: "Piezas Originales", description: "Envío a toda México" },
];
---

<Layout
	title="Página no encontrada | Pixel Fix"
	description="La página que buscas no existe o fue movida. Encuentra piezas, equipos y servicio de reparación para Google Pixel en Pixel Fix México."
	url="https://www.pixelfixmexico.com/404/"
>
	<main class="min-h-[70vh] flex items-center">
		<section class="max-w-3xl mx-auto px-6 py-24 text-center reveal">
			<span
				class="inline-flex items-center gap-2 px-3 py-1 bg-surface-muted border border-border text-muted-strong text-xs font-mono font-medium rounded-full tracking-wide uppercase mb-6"
			>
				Error 404
			</span>
			<h1 class="text-4xl md:text-5xl font-medium tracking-tight text-ink leading-[1.1] mb-4">
				Esta página no existe.
			</h1>
			<p class="text-base text-muted leading-relaxed max-w-lg mx-auto mb-10">
				Puede que el enlace esté roto o la página se haya movido. Prueba
				alguno de estos accesos directos, o escríbenos por WhatsApp si
				buscabas algo en específico.
			</p>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10 text-left">
				{
					links.map((link) => (
						<a
							href={link.href}
							data-umami-event="404_link_click"
							data-umami-event-page={link.label}
							class="bg-white border border-border-strong rounded-xl p-4 flex items-center justify-between gap-3 hover:border-ink hover:shadow-sm transition-all group"
						>
							<div>
								<p class="font-medium text-ink text-sm">{link.label}</p>
								<p class="text-xs text-muted-strong mt-0.5">{link.description}</p>
							</div>
							<Icon
								name="ph:arrow-right"
								class="w-4 h-4 text-muted-strong group-hover:text-ink group-hover:translate-x-0.5 transition-all flex-shrink-0"
							/>
						</a>
					))
				}
			</div>

			<div class="flex flex-wrap items-center justify-center gap-4">
				<a
					href="/"
					data-umami-event="404_home_click"
					class="inline-flex items-center justify-center px-6 py-3.5 bg-ink text-white text-xs font-mono font-medium rounded transition-transform hover:scale-[0.98]"
				>
					Volver al Inicio
				</a>
				<a
					href={`https://wa.me/${phoneNumber}?text=Hola%20Pixel%20Fix%2C%20no%20encontr%C3%A9%20lo%20que%20buscaba%20en%20su%20sitio.`}
					target="_blank"
					rel="noopener noreferrer"
					data-umami-event="404_whatsapp_click"
					class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-whatsapp text-white text-xs font-medium rounded-lg hover:bg-whatsapp-hover transition-colors"
				>
					<Icon name="simple-icons:whatsapp" class="w-4 h-4" />
					Escríbenos por WhatsApp
				</a>
			</div>
		</section>
	</main>
</Layout>
