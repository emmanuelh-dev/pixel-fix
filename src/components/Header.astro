---
import { Icon } from "astro-icon/components";
import { phoneNumber } from "../data/store";
---

<header class="w-full border-b border-border bg-bg/80 backdrop-blur-md sticky top-0 z-50">
	<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
		<a href="/" data-umami-event="header_logo_click" class="font-bold text-ink tracking-tight hover:opacity-80 transition-opacity">Pixel Fix.</a>
		<nav class="hidden md:flex items-center gap-6 text-xs font-mono tracking-wider uppercase text-muted">
			<a href="/" data-umami-event="header_nav_click" data-umami-event-page="inicio" class="hover:text-ink transition-colors">Inicio</a>
			<a href="/tienda" data-umami-event="header_nav_click" data-umami-event-page="tienda" class="hover:text-ink transition-colors">Tienda</a>
			<a href="/reparacion-google-pixel-monterrey" data-umami-event="header_nav_click" data-umami-event-page="reparacion" class="hover:text-ink transition-colors">Reparación</a>
			<a href="/venta-google-pixel-monterrey" data-umami-event="header_nav_click" data-umami-event-page="venta" class="hover:text-ink transition-colors">Venta</a>
			<a href="#testimoniales" data-umami-event="header_nav_click" data-umami-event-page="testimoniales" class="hover:text-ink transition-colors">Testimoniales</a>
		</nav>
		<div class="flex items-center gap-2">
			<a href="/tienda" data-umami-event="header_search_click" title="Buscar piezas y equipos" class="p-2 text-muted hover:text-ink hover:bg-border rounded-lg transition-all" aria-label="Buscar en tienda">
				<Icon name="ph:magnifying-glass" class="w-4 h-4" />
			</a>
			<a href={`https://wa.me/${phoneNumber}`} target="_blank" rel="noopener noreferrer" data-umami-event="header_contact_click" class="px-4 py-2 bg-ink text-white text-xs font-medium rounded transition-transform hover:scale-[0.98]">
				Contacto
			</a>
		</div>
	</div>
	
	<!-- Menú de Navegación Móvil (visible solo en móviles) -->
	<div class="md:hidden border-t border-border/50 bg-bg/95 py-2.5 px-6 flex items-center justify-center gap-6 text-[10px] font-mono tracking-wider uppercase text-muted">
		<a href="/" data-umami-event="header_nav_mobile_click" data-umami-event-page="inicio" class="hover:text-ink transition-colors">Inicio</a>
		<a href="/tienda" data-umami-event="header_nav_mobile_click" data-umami-event-page="tienda" class="hover:text-ink transition-colors">Tienda</a>
		<a href="/reparacion-google-pixel-monterrey" data-umami-event="header_nav_mobile_click" data-umami-event-page="reparacion" class="hover:text-ink transition-colors">Reparación</a>
		<a href="/venta-google-pixel-monterrey" data-umami-event="header_nav_mobile_click" data-umami-event-page="venta" class="hover:text-ink transition-colors">Venta</a>
		<a href="#testimoniales" data-umami-event="header_nav_mobile_click" data-umami-event-page="testimoniales" class="hover:text-ink transition-colors">Opiniones</a>
	</div>
</header>
