---
import { Icon } from "astro-icon/components";
import { phoneNumber } from "../data/store";
---

<header class="w-full border-b border-border bg-bg/80 backdrop-blur-md sticky top-0 z-50">
	<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
		<a href="/" data-umami-event="header_logo_click" class="font-bold text-ink tracking-tight hover:opacity-80 transition-opacity">Pixel Fix.</a>

		<!-- Nav desktop -->
		<nav class="hidden md:flex items-center gap-6 text-xs font-mono tracking-wider uppercase text-muted">
			<a href="/" data-umami-event="header_nav_click" data-umami-event-page="inicio" class="hover:text-ink transition-colors">Inicio</a>
			<a href="/tienda" data-umami-event="header_nav_click" data-umami-event-page="tienda" class="hover:text-ink transition-colors">Tienda</a>
			<a href="/reparacion-google-pixel-monterrey" data-umami-event="header_nav_click" data-umami-event-page="reparacion" class="hover:text-ink transition-colors">Reparación</a>
			<a href="/venta-google-pixel-monterrey" data-umami-event="header_nav_click" data-umami-event-page="venta" class="hover:text-ink transition-colors">Venta</a>
			<a href="/testimoniales" data-umami-event="header_nav_click" data-umami-event-page="testimoniales" class="hover:text-ink transition-colors">Testimoniales</a>
		</nav>

		<div class="flex items-center gap-2">
			<a href="/tienda" data-umami-event="header_search_click" title="Buscar piezas y equipos" class="p-2 text-muted hover:text-ink hover:bg-border rounded-lg transition-all" aria-label="Buscar en tienda">
				<Icon name="ph:magnifying-glass" class="w-4 h-4" />
			</a>
			<a href={`https://wa.me/${phoneNumber}`} target="_blank" rel="noopener noreferrer" data-umami-event="header_contact_click" class="hidden md:block px-4 py-2 bg-ink text-white text-xs font-medium rounded transition-transform hover:scale-[0.98]">
				Contacto
			</a>
			<!-- Hamburger (mobile only) -->
			<button
				id="menu-btn"
				class="md:hidden p-2 text-muted hover:text-ink rounded-lg transition-colors"
				aria-label="Abrir menú"
				aria-expanded="false"
			>
				<Icon name="ph:list" class="w-5 h-5" id="icon-open" />
				<Icon name="ph:x" class="w-5 h-5 hidden" id="icon-close" />
			</button>
		</div>
	</div>

	<!-- Drawer móvil -->
	<div
		id="mobile-menu"
		class="md:hidden hidden border-t border-border/60 bg-bg/90 backdrop-blur-md"
	>
		<nav class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-1">
			<a href="/" class="py-2.5 text-sm font-mono text-muted hover:text-ink transition-colors border-b border-border/40">Inicio</a>
			<a href="/tienda" class="py-2.5 text-sm font-mono text-muted hover:text-ink transition-colors border-b border-border/40">Tienda</a>
			<a href="/reparacion-google-pixel-monterrey" class="py-2.5 text-sm font-mono text-muted hover:text-ink transition-colors border-b border-border/40">Reparación</a>
			<a href="/venta-google-pixel-monterrey" class="py-2.5 text-sm font-mono text-muted hover:text-ink transition-colors border-b border-border/40">Venta</a>
			<a href="/testimoniales" class="py-2.5 text-sm font-mono text-muted hover:text-ink transition-colors border-b border-border/40">Testimoniales</a>
			<a
				href={`https://wa.me/${phoneNumber}`}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-3 flex items-center justify-center gap-2 py-2.5 bg-ink text-white text-xs font-mono rounded-lg"
			>
				Contacto por WhatsApp
			</a>
		</nav>
	</div>
</header>

<script>
	const btn = document.getElementById('menu-btn')!;
	const menu = document.getElementById('mobile-menu')!;
	const iconOpen = document.getElementById('icon-open')!;
	const iconClose = document.getElementById('icon-close')!;

	btn.addEventListener('click', () => {
		const open = menu.classList.toggle('hidden');
		iconOpen.classList.toggle('hidden', !open);
		iconClose.classList.toggle('hidden', open);
		btn.setAttribute('aria-expanded', String(!open));
	});

	// Cierra el menú al navegar
	menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
		menu.classList.add('hidden');
		iconOpen.classList.remove('hidden');
		iconClose.classList.add('hidden');
	}));
</script>
