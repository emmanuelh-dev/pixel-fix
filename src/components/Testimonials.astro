---
import fs from "node:fs";
import path from "node:path";

let testimonialImages = [];
try {
	const testimonialsDir = path.join(process.cwd(), "public/testimonials");
	if (fs.existsSync(testimonialsDir)) {
		testimonialImages = fs
			.readdirSync(testimonialsDir)
			.filter((file) => /\.(png|jpe?g|webp|svg|gif)$/i.test(file))
			.map((file) => `/testimonials/${file}`);
	}
} catch (e) {
	console.error("Error reading testimonials in component:", e);
}
---

<section
	id="testimoniales"
	class="max-w-5xl mx-auto px-6 py-24 border-t border-border reveal"
>
	<div class="mb-12 max-w-2xl">
		<h2
			class="text-3xl md:text-4xl tracking-tight text-ink mb-4"
		>
			Lo Que Dicen Nuestros Clientes.
		</h2>
		<p class="text-muted leading-[1.6]">
			Opiniones reales y capturas de conversaciones con clientes satisfechos que
			confiaron en Pixel Fix.
		</p>
	</div>

	{
		testimonialImages.length > 0 ? (
			<div>
				<div
					id="testimonials-grid"
					class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-6 items-start"
				>
					{testimonialImages.map((img, index) => (
						<div
							class={`testimonial-item bg-surface border border-border rounded-xl overflow-hidden shadow-[0_2px_8px_rgba(0,0,0,0.02)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 group ${index >= 6 ? "hidden" : index >= 4 ? "hidden md:block" : ""}`}
						>
							<div class="p-2 bg-surface-muted border-b border-border flex items-center justify-between text-[9px] sm:text-[10px] text-muted font-mono">
								<span>Evidencia Real</span>
								<a
									href={img}
									target="_blank"
									rel="noopener noreferrer"
									class="hover:text-ink transition-colors underline"
								>
									Ampliar
								</a>
							</div>
							<div class="relative overflow-hidden bg-bg flex items-center justify-center p-2 sm:p-4">
								<img
									src={img}
									alt="Captura de testimonio de Google Pixel"
									class="w-full h-auto max-h-[300px] sm:max-h-[400px] object-cover rounded-lg border border-border/50 opacity-95 saturate-[0.85] contrast-[1.05] group-hover:scale-[1.01] transition-transform duration-500"
									loading="lazy"
								/>
							</div>
						</div>
					))}
				</div>
				{testimonialImages.length > 4 && (
					<div class="mt-8 flex justify-center">
						<button
							id="btn-show-more"
							class="px-6 py-3 border border-border bg-white text-xs font-mono font-medium rounded hover:bg-surface-muted transition-colors active:scale-[0.98]"
						>
							Ver más testimoniales
						</button>
					</div>
				)}
			</div>
		) : (
			<div class="border border-dashed border-border rounded-xl p-12 text-center text-sm text-muted bg-surface-muted/50">
				<p class="mb-2 font-mono">
					No hay capturas de testimoniales cargadas aún.
				</p>
				<p class="text-xs text-muted">
					Coloca capturas de WhatsApp o Google Maps en la carpeta{" "}
					<code class="bg-surface-muted px-1 py-0.5 rounded border border-border text-xs font-mono">
						public/testimonials/
					</code>{" "}
					y aparecerán aquí automáticamente.
				</p>
			</div>
		)
	}
</section>

<script>
	const btn = document.getElementById("btn-show-more");
	if (btn) {
		btn.addEventListener("click", () => {
			const hiddenItems = document.querySelectorAll(".testimonial-item.hidden");
			hiddenItems.forEach((item) => {
				item.classList.remove("hidden");
			});
			btn.style.display = "none";
		});
	}
</script>
