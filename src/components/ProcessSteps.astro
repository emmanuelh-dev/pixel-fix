---
interface Props {
	title: string;
	description: string;
	steps: { title: string; description: string }[];
	id?: string;
}

const { title, description, steps, id = "proceso" } = Astro.props;
---

<section id={id} class="max-w-5xl mx-auto px-6 py-24 border-t border-border reveal">
	<div class="mb-16 max-w-xl">
		<h2 class="text-3xl md:text-4xl tracking-tight text-ink mb-4">{title}</h2>
		<p class="text-muted leading-[1.6]">{description}</p>
	</div>

	<div class="grid md:grid-cols-3 gap-6">
		{
			steps.map((step, i) => (
				<div class="bg-surface-muted border border-border p-8 rounded-xl flex flex-col">
					<div class="text-muted font-mono text-xs mb-4 border border-border bg-surface w-8 h-8 flex items-center justify-center rounded">
						{String(i + 1).padStart(2, "0")}
					</div>
					<h3 class="text-base font-medium text-ink mb-2">{step.title}</h3>
					<p class="text-muted text-sm leading-[1.6]">{step.description}</p>
				</div>
			))
		}
	</div>
</section>
