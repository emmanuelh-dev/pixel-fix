---
// ponytail: carrito global via localStorage + window.pfCart API
import { Icon } from "astro-icon/components";
import { phoneNumber, shippingCost } from "../data/store";
---

<!-- Carrito flotante -->
<div id="cart-bubble" class="fixed bottom-6 right-6 z-50 hidden">
  <button id="cart-toggle" class="flex items-center gap-2.5 pl-4 pr-5 py-3 bg-ink text-white rounded-full shadow-2xl font-medium text-sm hover:bg-ink-hover transition-colors">
    <div class="relative">
      <Icon name="ph:shopping-cart" class="w-4 h-4" />
      <span id="cart-badge" class="absolute -top-2 -right-2 w-4 h-4 bg-accent text-white text-[9px] font-bold rounded-full flex items-center justify-center">0</span>
    </div>
    Carrito · <span id="cart-total-bubble">$0</span>
  </button>
</div>

<!-- Panel carrito -->
<div id="cart-panel" class="fixed inset-y-0 right-0 w-full sm:w-[400px] bg-white shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-out flex flex-col">
  <div class="flex items-center justify-between px-6 py-4 border-b border-border">
    <div class="flex items-center gap-2">
      <Icon name="ph:shopping-cart" class="w-5 h-5 text-ink" />
      <h2 class="font-semibold text-ink">Carrito</h2>
      <span id="cart-count" class="px-2 py-0.5 bg-bg text-muted text-xs font-mono rounded-full">0</span>
    </div>
    <button id="cart-close" class="p-1.5 text-muted hover:text-ink hover:bg-bg rounded-lg transition-all">
      <Icon name="ph:x" class="w-4 h-4" />
    </button>
  </div>
  <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4 space-y-3"></div>
  <div class="px-6 py-5 border-t border-border space-y-3">
    <div class="flex justify-between items-center text-sm text-muted">
      <span>Subtotal piezas</span>
      <span id="cart-subtotal" class="font-mono">$0 MXN</span>
    </div>
    <div class="flex justify-between items-center text-sm text-muted">
      <span>Envío a todo México</span>
      <span id="cart-shipping" class="font-mono">$0 MXN</span>
    </div>
    <div class="flex justify-between items-center pt-1 border-t border-border">
      <span class="text-sm text-muted">Total estimado</span>
      <span id="cart-total" class="font-bold text-ink">$0 MXN</span>
    </div>
    <div class="flex items-center gap-1.5 text-[11px] text-faint">
      <Icon name="ph:truck" class="w-3 h-3" />
      10–12 días hábiles
    </div>
    <a id="cart-wa-link" href="#" target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 w-full py-3.5 bg-whatsapp text-white rounded-xl font-semibold hover:bg-whatsapp-hover transition-colors text-sm">
      <Icon name="simple-icons:whatsapp" class="w-4 h-4" />
      Pedir por WhatsApp
    </a>
    <button id="cart-clear" class="w-full py-2 text-[11px] text-faint hover:text-red-500 transition-colors">Vaciar carrito</button>
  </div>
</div>
<div id="cart-overlay" class="fixed inset-0 bg-black/40 z-[99] hidden backdrop-blur-sm"></div>

<script define:vars={{ phoneNumber, shippingCost }}>
  const WA  = phoneNumber;
  const SHIPPING = shippingCost;
  const fmt  = n => new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 }).format(n) + ' MXN';
  const fmtS = n => new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 }).format(n);

  let cart = JSON.parse(localStorage.getItem('pf-cart') || '[]');
  // Migra carritos guardados antes del soporte de cantidades (sin campo qty -> NaN en totales)
  cart = cart
    .map(i => ({ ...i, price: Number(i.price) || 0, qty: Number(i.qty) || 1 }))
    .filter(i => i.id && i.price > 0);
  const save = () => localStorage.setItem('pf-cart', JSON.stringify(cart));

  function syncUI() {
    const units = cart.reduce((s, i) => s + i.qty, 0);
    const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
    const shipping = units > 0 ? SHIPPING : 0;
    const total = subtotal + shipping;
    document.getElementById('cart-count').textContent   = units;
    document.getElementById('cart-badge').textContent   = units;
    document.getElementById('cart-subtotal').textContent = fmt(subtotal);
    document.getElementById('cart-shipping').textContent = fmt(shipping);
    document.getElementById('cart-total').textContent   = fmt(total);
    document.getElementById('cart-total-bubble').textContent = fmtS(total);
    document.getElementById('cart-bubble').classList.toggle('hidden', units === 0);

    document.getElementById('cart-items').innerHTML = cart.length
      ? cart.map(item => `
          <div class="flex items-start gap-3 py-3 border-b border-bg last:border-0">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-ink truncate">${item.name}</p>
              <p class="text-xs text-muted mt-0.5">${item.part}</p>
              <div class="flex items-center gap-3 mt-1.5">
                <div class="flex items-center gap-2 border border-border rounded-lg px-1">
                  <button data-decr="${item.id}" class="qty-btn w-5 h-5 flex items-center justify-center text-muted hover:text-ink">−</button>
                  <span class="text-xs font-mono w-4 text-center">${item.qty}</span>
                  <button data-incr="${item.id}" class="qty-btn w-5 h-5 flex items-center justify-center text-muted hover:text-ink">+</button>
                </div>
                <p class="text-sm font-bold text-ink">${fmt(item.price * item.qty)}</p>
              </div>
            </div>
            <button data-remove="${item.id}" class="remove-btn p-1.5 text-faint hover:text-red-500 hover:bg-red-50 rounded-lg transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>`).join('')
      : `<div class="flex flex-col items-center justify-center py-12 text-center gap-3">
           <svg class="w-10 h-10 text-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
             <line x1="3" y1="6" x2="21" y2="6" stroke-width="1.5"/>
             <path d="M16 10a4 4 0 01-8 0" stroke-width="1.5"/>
           </svg>
           <p class="text-sm text-faint">Carrito vacío</p>
         </div>`;

    document.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', () => window.pfCart.remove(btn.dataset.remove));
    });
    document.querySelectorAll('[data-incr]').forEach(btn => {
      btn.addEventListener('click', () => window.pfCart.setQty(btn.dataset.incr, (cart.find(c => c.id === btn.dataset.incr)?.qty || 0) + 1));
    });
    document.querySelectorAll('[data-decr]').forEach(btn => {
      btn.addEventListener('click', () => window.pfCart.setQty(btn.dataset.decr, (cart.find(c => c.id === btn.dataset.decr)?.qty || 0) - 1));
    });

    const msg = cart.length
      ? encodeURIComponent(
          'Hola! Me interesan estas piezas:\n\n' +
          cart.map(i => `• ${i.name} — ${i.part} x${i.qty}\n  Precio: ${fmt(i.price * i.qty)}`).join('\n') +
          `\n\nEnvío a todo México: ${fmt(shipping)}\nTotal estimado: ${fmt(total)}` +
          '\n\n¿Pueden confirmar disponibilidad y forma de pago?'
        )
      : '';
    document.getElementById('cart-wa-link').href = `https://wa.me/${WA}?text=${msg}`;
  }

  // Panel
  const panel   = document.getElementById('cart-panel');
  const overlay = document.getElementById('cart-overlay');
  const openCart  = () => { panel.classList.replace('translate-x-full','translate-x-0'); overlay.classList.remove('hidden'); document.body.style.overflow='hidden'; };
  const closeCart = () => { panel.classList.replace('translate-x-0','translate-x-full'); overlay.classList.add('hidden');    document.body.style.overflow=''; };
  document.getElementById('cart-toggle').addEventListener('click', openCart);
  document.getElementById('cart-close').addEventListener('click',  closeCart);
  overlay.addEventListener('click', closeCart);
  document.getElementById('cart-clear').addEventListener('click', () => {
    cart.forEach(i => window.pfCart.updateBtn(i.id, 0));
    cart = []; save(); syncUI(); closeCart();
  });

  // API global que cualquier página puede usar
  window.pfCart = {
    // Agrega una unidad mas (o crea la linea con qty 1)
    add(id, name, part, price) {
      const item = cart.find(c => c.id === id);
      if (item) item.qty += 1;
      else cart.push({ id, name, part, price: Number(price), qty: 1 });
      this.updateBtn(id, cart.find(c => c.id === id).qty);
      save(); syncUI();
    },
    setQty(id, qty) {
      if (qty <= 0) return this.remove(id);
      const item = cart.find(c => c.id === id);
      if (item) item.qty = qty;
      this.updateBtn(id, qty);
      save(); syncUI();
    },
    remove(id) {
      cart = cart.filter(c => c.id !== id);
      this.updateBtn(id, 0);
      save(); syncUI();
    },
    // Pinta el botón .add-btn[data-id=id] donde sea que esté en el DOM
    updateBtn(id, qty) {
      const inCart = qty > 0;
      document.querySelectorAll(`.add-btn[data-id="${id}"]`).forEach(btn => {
        const label = btn.querySelector('.btn-label');
        const iconCart  = btn.querySelector('.btn-icon-cart');
        const iconCheck = btn.querySelector('.btn-icon-check');
        if (label)     label.textContent = inCart ? `En el carrito (${qty})` : 'Agregar al carrito';
        if (iconCart)  iconCart.classList.toggle('hidden',  inCart);
        if (iconCheck) iconCheck.classList.toggle('hidden', !inCart);
        btn.classList.toggle('bg-accent-soft', inCart);  btn.classList.toggle('text-accent', inCart);
        btn.classList.toggle('bg-ink',  !inCart); btn.classList.toggle('text-white',     !inCart);
      });
    },
    isInCart(id) { return cart.some(c => c.id === id); },
    open: openCart,
  };

  // Restaurar estado de todos los botones de la página actual
  cart.forEach(item => window.pfCart.updateBtn(item.id, item.qty));
  syncUI();
</script>
