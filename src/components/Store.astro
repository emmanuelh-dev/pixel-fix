---
import Layout from "../layouts/Layout.astro";
import { repairCatalog, salesCatalog, formatPrice } from "../data/catalog";
import { phoneNumber } from "../data/store";

function splitModels(raw: string): string[] {
	if (!raw.includes("/")) return [raw.trim()];
	return raw.split("/").map((m) => {
		m = m.trim();
		return m.startsWith("Pixel") ? m : `Pixel ${m}`;
	});
}

const MODEL_ORDER = [
	"Pixel 10 Pro XL",
	"Pixel 10 Pro",
	"Pixel 10",
	"Pixel 10a",
	"Pixel 9 Pro XL",
	"Pixel 9 Pro",
	"Pixel 9",
	"Pixel 9a",
	"Pixel 8 Pro",
	"Pixel 8",
	"Pixel 8a",
	"Pixel 7 Pro",
	"Pixel 7",
	"Pixel 7a",
	"Pixel 6 Pro",
	"Pixel 6",
	"Pixel 6a",
	"Pixel 5",
	"Pixel 5a",
];

function getSeries(model: string): string {
	if (model.includes("10")) return "Pixel 10 Series";
	if (model.includes("9")) return "Pixel 9 Series";
	if (model.includes("8")) return "Pixel 8 Series";
	if (model.includes("7")) return "Pixel 7 Series";
	if (model.includes("6")) return "Pixel 6 Series";
	if (model.includes("5")) return "Pixel 5 Series";
	return "Otros";
}

const allParts = repairCatalog.flatMap((series) =>
	series.parts.flatMap((p) => {
		const isBateria = p.name.toLowerCase().includes("pila");
		const isOriginal = p.name.toLowerCase().includes("original");
		const qualityTag = isOriginal ? "original" : "replica-excelente";
		const rawSlug = p.model
			.toLowerCase()
			.replace(/\s*\/\s*/g, "-")
			.replace(/\s+/g, "-")
			.replace(/[^a-z0-9-]/g, "");

		return splitModels(p.model).map((model) => {
			const seriesName = getSeries(model);
			return {
				id: `${series.id}-${model.toLowerCase().replace(/\s+/g, "-")}-${isBateria ? "bat" : "pan"}-${qualityTag}`,
				slug: `${isBateria ? "bateria" : "pantalla"}-${rawSlug}-${qualityTag}`,
				type: isBateria ? "Batería" : "Pantalla",
				iconType: isBateria ? "battery" : "screen",
				name: p.name,
				model,
				series: seriesName,
				pricePart: p.pricePart,
				priceInstall: p.priceInstall,
				delivery: p.delivery,
				category: "refaccion" as const,
			};
		});
	}),
);

const allDevices = salesCatalog.flatMap((series) =>
	series.devices.map((d) => {
		const model = d.name.replace(/^Google\s+/, "");
		const seriesName = getSeries(model);
		return {
			id: `${series.id}-${model.toLowerCase().replace(/\s+/g, "-")}-equipo`,
			slug: "",
			type: "Equipo" as const,
			iconType: "device",
			name: d.name,
			model,
			series: seriesName,
			pricePart: d.price,
			priceInstall: 0,
			delivery: d.availability,
			specs: (d as any).specs,
			category: "equipo" as const,
		};
	}),
);

const catalog = [...allParts, ...allDevices];
const availableModels = MODEL_ORDER.filter((m) =>
	catalog.some((i) => i.model === m),
);

const availableSeries = [
	"Pixel 10 Series",
	"Pixel 9 Series",
	"Pixel 8 Series",
	"Pixel 7 Series",
	"Pixel 6 Series",
	"Pixel 5 Series",
].filter((s) => catalog.some((item) => item.series === s));

const fmt = (n: number) => formatPrice(n);
---

<div>
	<main class="min-h-screen max-w-5xl mx-auto px-4 py-12 md:py-20">
		<div class="relative mb-6">
			<svg
				class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#333333] pointer-events-none"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				stroke-width="1.5"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
			</svg>
			<input
				id="search-input"
				type="search"
				placeholder='Ej: "pantalla pixel 8", "batería pixel 7 pro"…'
				class="w-full pl-11 pr-4 py-3.5 bg-white border border-[#888888] rounded-xl text-[#111111] placeholder-[#555555] focus:outline-none focus:ring-2 focus:ring-[#111111]/10 text-sm shadow-sm"
			/>
		</div>

		<div class="mb-4">
			<p
				class="text-[10px] font-mono uppercase tracking-wider text-[#333333] mb-2"
			>
				Tipo
			</p>
			<div id="type-filters" class="flex flex-wrap gap-2">
				<button
					data-type="all"
					class="type-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
					>Todo</button
				>
				{
					(["Pantalla", "Batería", "Equipo"] as const).map((t) => (
						<button
							data-type={t}
							class="type-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all flex items-center gap-1.5"
						>
							{t === "Pantalla" && (
								<svg
									class="w-3 h-3"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									stroke-width="1.5"
								>
									<rect x="5" y="2" width="14" height="20" rx="2" />
									<line x1="12" y1="18" x2="12.01" y2="18" />
								</svg>
							)}
							{t === "Batería" && (
								<svg
									class="w-3 h-3"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									stroke-width="1.5"
								>
									<rect x="2" y="7" width="16" height="10" rx="2" />
									<path d="M22 11v2" />
								</svg>
							)}
							{t === "Equipo" && (
								<svg
									class="w-3 h-3"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									stroke-width="1.5"
								>
									<rect x="4" y="2" width="16" height="20" rx="2" />
									<path d="M12 18h.01" />
								</svg>
							)}
							{t}
						</button>
					))
				}
			</div>
		</div>

		<div class="mb-4">
			<p
				class="text-[10px] font-mono uppercase tracking-wider text-[#333333] mb-2"
			>
				Serie
			</p>
			<div id="series-filters" class="flex flex-wrap gap-2">
				<button
					data-series="all"
					class="series-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
					>Todas las series</button
				>
				{
					availableSeries.map((s) => (
						<button
							data-series={s}
							class="series-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
						>
							{s}
						</button>
					))
				}
			</div>
		</div>

		<div class="mb-6">
			<p
				class="text-[10px] font-mono uppercase tracking-wider text-[#333333] mb-2"
			>
				Modelo Específico
			</p>
			<div id="model-filters" class="flex flex-wrap gap-2">
				<button
					data-model="all"
					class="model-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
					>Todos los modelos</button
				>
				{
					availableModels.map((m) => {
						const parentSeries = getSeries(m);
						return (
							<button
								data-model={m}
								data-parent-series={parentSeries}
								class="model-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
							>
								{m}
							</button>
						);
					})
				}
			</div>
		</div>

		<p id="results-count" class="text-xs font-mono text-[#333333] mb-4">
			{catalog.length} productos disponibles
		</p>

		<div
			id="catalog-grid"
			class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-24"
		>
			{
				catalog.map((item) => {
					const CardContainer = item.slug ? "a" : "div";
					const containerProps = item.slug
						? { href: `/productos/${item.slug}` }
						: {};
					const whatsappText = encodeURIComponent(
						`Hola, me interesa comprar el siguiente producto:\n\n*Modelo:* ${item.model}\n*Detalle:* ${item.category === "equipo" ? (item as any).specs : item.name}\n*Precio:* ${fmt(item.pricePart)}`,
					);
					const whatsappUrl = `https://wa.me/${phoneNumber}?text=${whatsappText}`;

					return (
						<div
							class="catalog-card bg-white border border-[#A0A0A0] rounded-xl p-5 flex flex-col gap-4 hover:shadow-sm hover:border-[#111111] transition-all"
							data-type={item.type}
							data-series={item.series}
							data-model={item.model}
							data-text={`${item.name} ${item.model} ${item.type} ${item.series} original bateria pantalla pixel ${(item as any).specs || ""}`.toLowerCase()}
						>
							<CardContainer
								{...containerProps}
								class="flex flex-col gap-4 flex-1 block select-none cursor-pointer"
							>
								<div class="flex items-start justify-between gap-3">
									<div class="flex-1 min-w-0">
										<span class="text-[10px] font-mono uppercase tracking-wider text-[#333333]">
											{item.type}
										</span>
										<p class="font-medium text-[#111111] text-sm leading-snug mt-0.5">
											{item.model}
										</p>
										<p class="text-xs text-[#555555] mt-0.5 line-clamp-1">
											{item.category === "equipo"
												? (item as any).specs
												: item.name}
										</p>
									</div>
									<div class="w-8 h-8 flex items-center justify-center rounded-lg bg-[#F9F9F9] text-[#333333] border border-[#EAEAEA] flex-shrink-0">
										{item.iconType === "screen" && (
											<svg
												class="w-4 h-4"
												fill="none"
												stroke="currentColor"
												viewBox="0 0 24 24"
												stroke-width="1.5"
											>
												<rect x="5" y="2" width="14" height="20" rx="2" />
												<line x1="12" y1="18" x2="12.01" y2="18" />
											</svg>
										)}
										{item.iconType === "battery" && (
											<svg
												class="w-4 h-4"
												fill="none"
												stroke="currentColor"
												viewBox="0 0 24 24"
												stroke-width="1.5"
											>
												<rect x="2" y="7" width="16" height="10" rx="2" />
												<path d="M22 11v2" />
											</svg>
										)}
										{item.iconType === "device" && (
											<svg
												class="w-4 h-4"
												fill="none"
												stroke="currentColor"
												viewBox="0 0 24 24"
												stroke-width="1.5"
											>
												<rect x="4" y="2" width="16" height="20" rx="2" />
												<path d="M12 18h.01" />
											</svg>
										)}
									</div>
								</div>

								<div>
									<p class="text-lg font-bold text-[#111111] font-mono">
										{fmt(item.pricePart)}
									</p>
									{item.category !== "equipo" && item.priceInstall > 0 && (
										<p class="text-[11px] text-[#333333]">
											Con instalación MTY: {fmt(item.priceInstall)}
										</p>
									)}
									<div class="flex items-center gap-1.5 mt-2">
										<svg
											class="w-3.5 h-3.5 text-[#555555]"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											stroke-width="1.5"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25c0-.446-.26-.846-.662-1.012l-4.185-1.724a1.056 1.056 0 0 0-.965.06l-2.45c-.394.246-.632.678-.632 1.144V18.75m-6 0h6M16.5 18.75V11.25m0 0H9m7.5 0h2.25m-11.25 0H4.5m0 0v-3.75c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125V11.25M4.5 11.25H9"
											/>
										</svg>
										<p class="text-[11px] text-[#555555]">{item.delivery}</p>
									</div>
								</div>
							</CardContainer>

							<div class="flex items-center gap-2 mt-auto">
								<a
									href={whatsappUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="px-3 py-2 text-[11px] font-mono border border-[#888888] rounded-lg text-[#333333] hover:border-[#111111] hover:text-[#111111] hover:bg-[#F9F9F9] transition-all whitespace-nowrap"
								>
									Comprar
								</a>
								<button
									data-id={item.id}
									data-name={item.model}
									data-part={item.name}
									data-price={item.pricePart}
									class="add-btn flex-1 flex items-center justify-center gap-1.5 py-2 px-3 bg-[#111111] text-white text-[11px] font-medium rounded-lg hover:bg-[#222222] transition-colors"
								>
									<svg
										class="w-3.5 h-3.5 btn-icon-cart"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
										stroke-width="1.5"
									>
										<>
											<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
											<line x1="3" y1="6" x2="21" y2="6" />
											<path d="M16 10a4 4 0 01-8 0" />
										</>
									</svg>
									<span class="btn-label">Agregar al carrito</span>
								</button>
							</div>
						</div>
					);
				})
			}
		</div>

		<div
			id="no-results"
			class="hidden py-16 text-center text-[#333333] text-sm"
		>
			Sin resultados. Intenta con "pixel 8", "pantalla" o "batería".
		</div>
	</main>

	<style>
		.chip-active {
			background: #111111;
			color: #ffffff;
			border-color: #111111;
			font-weight: 500;
		}
		.chip-inactive {
			background: transparent;
			color: #333333;
			border-color: #888888;
			font-weight: 400;
		}
		.chip-inactive:hover {
			border-color: #111111;
			color: #000000;
			background: #f5f5f5;
		}
	</style>

	<script>
		let activeType = "all",
			activeSeries = "all",
			activeModel = "all",
			query = "";

		function updateModelChipsVisibility() {
			const modelButtons = document.querySelectorAll(".model-btn");
			modelButtons.forEach((btn) => {
				const el = btn as HTMLElement;
				if (el.dataset.model === "all") return;

				if (
					activeSeries !== "all" &&
					el.dataset.parentSeries !== activeSeries
				) {
					el.style.display = "none";
					if (activeModel === el.dataset.model) {
						activeModel = "all";
						const allModelBtn = document.querySelector(
							'.model-btn[data-model="all"]',
						);
						if (allModelBtn) activateChip("model-btn", allModelBtn);
					}
				} else {
					el.style.display = "";
				}
			});
		}

		function applyFilter() {
			updateModelChipsVisibility();

			const cards = document.querySelectorAll(".catalog-card");
			let visible = 0;

			cards.forEach((card) => {
				const el = card as HTMLElement;
				const matchType =
					activeType === "all" || el.dataset.type === activeType;
				const matchSeries =
					activeSeries === "all" || el.dataset.series === activeSeries;
				const matchModel =
					activeModel === "all" || el.dataset.model === activeModel;

				const words = query.toLowerCase().split(/\s+/).filter(Boolean);
				const matchQuery =
					!words.length ||
					words.every((w) => (el.dataset.text || "").includes(w));

				const show = matchType && matchSeries && matchModel && matchQuery;
				el.style.display = show ? "" : "none";
				if (show) visible++;
			});

			const countEl = document.getElementById("results-count");
			if (countEl) {
				countEl.textContent = `${visible} producto${visible !== 1 ? "s" : ""} disponible${visible !== 1 ? "s" : ""}`;
			}

			document
				.getElementById("no-results")!
				.classList.toggle("hidden", visible > 0);
			document
				.getElementById("catalog-grid")!
				.classList.toggle("hidden", visible === 0);
		}

		function activateChip(cls: string, selected: Element) {
			document.querySelectorAll(`.${cls}`).forEach((b) => {
				b.className =
					b.className.replace(/chip-\w+/g, "").trim() +
					(b === selected ? " chip-active" : " chip-inactive");
			});
		}

		document.getElementById("type-filters")!.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".type-btn") as HTMLElement;
			if (!btn) return;
			activeType = btn.dataset.type!;
			activateChip("type-btn", btn);
			applyFilter();
		});

		document
			.getElementById("series-filters")!
			.addEventListener("click", (e) => {
				const btn = (e.target as Element).closest(".series-btn") as HTMLElement;
				if (!btn) return;
				activeSeries = btn.dataset.series!;
				activateChip("series-btn", btn);
				applyFilter();
			});

		document.getElementById("model-filters")!.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".model-btn") as HTMLElement;
			if (!btn) return;
			activeModel = btn.dataset.model!;
			activateChip("model-btn", btn);
			applyFilter();
		});

		document.getElementById("search-input")!.addEventListener("input", (e) => {
			query = (e.target as HTMLInputElement).value;
			applyFilter();
		});

		document.getElementById("catalog-grid")!.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".add-btn") as HTMLElement;
			if (!btn || !window.pfCart) return;
			window.pfCart.toggle(
				btn.dataset.id!,
				btn.dataset.name!,
				btn.dataset.part!,
				Number(btn.dataset.price),
			);
		});
	</script>
</div>
