---
import fs from "node:fs";
import path from "node:path";
import { Icon } from "astro-icon/components";
import {
	storeCatalog,
	storeAvailableModels as allAvailableModels,
	storeAvailableSeries as allAvailableSeries,
	formatPrice,
	getSeries,
	deviceImageFallback,
} from "../data/catalog";
import { phoneNumber } from "../data/store";

interface Props {
	categoryFilter?: "equipo" | "refaccion" | "all";
}

const { categoryFilter = "all" } = Astro.props;

const catalog = categoryFilter === "all"
	? storeCatalog
	: storeCatalog.filter((i) => i.category === categoryFilter);

const availableModels = allAvailableModels.filter((m) =>
	catalog.some((i) => i.model === m),
);
const availableSeries = allAvailableSeries.filter((s) =>
	catalog.some((i) => i.series === s),
);

const fmt = (n: number, g: number = 0) => formatPrice(n, g);

const imgDir = path.join(process.cwd(), "public/images/productos");
const EXTS = ["webp", "jpg", "jpeg", "png"];

function resolveDeviceImage(slug: string): string | null {
	const candidates = [slug, deviceImageFallback[slug]].filter(Boolean);
	for (const s of candidates) {
		for (const ext of EXTS) {
			if (fs.existsSync(path.join(imgDir, `${s}.${ext}`))) {
				return `/images/productos/${s}.${ext}`;
			}
		}
	}
	return null;
}

const productImages = new Map<string, string>();
for (const item of catalog) {
	const img = resolveDeviceImage(item.slug);
	if (img) productImages.set(item.slug, img);
}

const typeIcon = {
	screen: "ph:rectangle",
	battery: "ph:battery-charging-vertical",
	device: "ph:device-mobile",
} as const;

const onlyEquipo = categoryFilter === "equipo";
const searchPlaceholder = onlyEquipo
	? 'Ej: "Pixel 9 Pro", "Pixel 8a", "Pixel 10"…'
	: 'Ej: "pantalla pixel 8", "batería pixel 7 pro"…';
---

<div>
	<main class="min-h-screen max-w-5xl mx-auto px-4 py-12 md:py-20">
		<div class="relative mb-6">
			<Icon name="ph:magnifying-glass" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-strong pointer-events-none" />
			<input
				id="search-input"
				type="search"
				placeholder={searchPlaceholder}
				class="w-full pl-11 pr-4 py-3.5 bg-white border border-border-strong rounded-xl text-ink placeholder-muted-strong focus:outline-none focus:ring-2 focus:ring-ink/10 text-sm shadow-sm"
			/>
		</div>

		{!onlyEquipo && (
			<div class="mb-4">
				<p
					class="text-[10px] font-mono uppercase tracking-wider text-muted-strong mb-2"
				>
					Tipo
				</p>
				<div id="type-filters" class="flex flex-wrap gap-2">
					<button
						data-type="all"
						class="type-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
						>Todo</button
					>
					{
						(["Pantalla", "Batería", "Equipo"] as const).map((t) => (
							<button
								data-type={t}
								class="type-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all flex items-center gap-1.5"
							>
								<Icon
									name={typeIcon[t === "Pantalla" ? "screen" : t === "Batería" ? "battery" : "device"]}
									class="w-3 h-3"
								/>
								{t}
							</button>
						))
					}
				</div>
			</div>
		)}

		<div class="mb-4">
			<p
				class="text-[10px] font-mono uppercase tracking-wider text-muted-strong mb-2"
			>
				Serie
			</p>
			<div id="series-filters" class="flex flex-wrap gap-2">
				<button
					data-series="all"
					class="series-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
					>Todas las series</button
				>
				{
					availableSeries.map((s) => (
						<button
							data-series={s}
							class="series-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
						>
							{s}
						</button>
					))
				}
			</div>
		</div>

		<div id="model-filters-container" class="mb-6 hidden">
			<p
				class="text-[10px] font-mono uppercase tracking-wider text-muted-strong mb-2"
			>
				Modelo Específico
			</p>
			<div id="model-filters" class="flex flex-wrap gap-2">
				<button
					data-model="all"
					class="model-btn chip-active px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
					>Todos los modelos</button
				>
				{
					availableModels.map((m) => {
						const parentSeries = getSeries(m);
						return (
							<button
								data-model={m}
								data-parent-series={parentSeries}
								class="model-btn chip-inactive px-3 py-1.5 text-xs font-mono rounded-full border transition-all"
							>
								{m}
							</button>
						);
					})
				}
			</div>
		</div>

		<p id="results-count" data-noun={onlyEquipo ? "modelo" : "producto"} class="text-xs font-mono text-muted-strong mb-4">
			{catalog.length} {onlyEquipo ? "modelos disponibles" : "productos disponibles"}
		</p>

		<div
			id="catalog-grid"
			class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-24"
		>
			{
				catalog.map((item) => {
					const CardContainer = item.slug ? "a" : "div";
					const containerProps = item.slug
						? { href: `/productos/${item.slug}` }
						: {};
					const whatsappText = encodeURIComponent(
						`Hola, me interesa comprar el siguiente producto:\n\n*Modelo:* ${item.model}\n*Detalle:* ${item.category === "equipo" ? (item as any).specs : item.name}\n*Precio:* ${fmt(item.pricePart, item.ganancia)}`,
					);
					const whatsappUrl = `https://wa.me/${phoneNumber}?text=${whatsappText}`;

					const productImg = productImages.get(item.slug) ?? null;

					return (
						<div
							class="catalog-card bg-white border border-border-strong rounded-2xl overflow-hidden flex flex-row hover:shadow-sm hover:border-ink transition-all"
							data-type={item.type}
							data-series={item.series}
							data-model={item.model}
							data-text={`${item.name} ${item.model} ${item.type} ${item.series} original bateria pantalla pixel ${item.specs || ""}`.toLowerCase()}
						>
							<!-- Imagen: columna izquierda, ancho fijo, alto completo -->
							<CardContainer {...containerProps} class="w-28 sm:w-32 flex-shrink-0 block select-none cursor-pointer overflow-hidden">
								{productImg ? (
									<img
										src={productImg}
										alt={item.model}
										class="w-full h-full object-cover"
										loading="lazy"
									/>
								) : (
									<div class="w-full h-full min-h-[160px] bg-surface-muted flex items-center justify-center border-r border-border">
										<Icon name={typeIcon[item.iconType]} class="w-8 h-8 text-muted" />
									</div>
								)}
							</CardContainer>

							<!-- Contenido: columna derecha -->
							<div class="flex-1 p-4 flex flex-col gap-3 min-w-0">
								<CardContainer
									{...containerProps}
									class="flex flex-col gap-3 flex-1 select-none cursor-pointer min-w-0"
								>
									<div class="min-w-0">
										<span class="text-[10px] font-mono uppercase tracking-wider text-muted-strong">
											{item.category === "equipo" && item.condition ? item.condition : item.type}
										</span>
										<p class="font-medium text-ink text-sm leading-snug mt-0.5 line-clamp-2">
											{item.model}
										</p>
										<p class="text-xs text-muted-strong mt-0.5 line-clamp-1">
											{item.category === "equipo"
												? item.specs
												: item.name}
										</p>
									</div>

									<div class="mt-auto">
										<p class="text-base font-bold text-ink font-mono">
											{fmt(item.pricePart, item.ganancia)}
										</p>
										{item.category !== "equipo" && item.priceInstall > 0 && (
											<p class="text-[11px] text-muted-strong">
												+{fmt(item.priceInstall)} instalación MTY
											</p>
										)}
										<div class="flex items-center gap-1.5 mt-1.5">
											<Icon name="ph:truck" class="w-3 h-3 text-muted-strong flex-shrink-0" />
											<p class="text-[10px] text-muted-strong leading-snug">{item.delivery}</p>
										</div>
									</div>
								</CardContainer>

								<div class="flex items-center gap-2">
									<a
										href={whatsappUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="px-3 py-2 text-[11px] font-mono border border-border-strong rounded-lg text-muted-strong hover:border-ink hover:text-ink hover:bg-surface-muted transition-all whitespace-nowrap"
									>
										Comprar
									</a>
									<button
										data-id={item.id}
										data-name={item.model}
										data-part={item.name}
										data-price={item.pricePart}
										class="add-btn flex-1 flex items-center justify-center gap-1.5 py-2 px-3 bg-ink text-white text-[11px] font-medium rounded-lg hover:bg-ink-hover transition-colors"
									>
										<Icon name="ph:shopping-cart" class="w-3.5 h-3.5 btn-icon-cart" />
										<Icon name="ph:check" class="w-3.5 h-3.5 btn-icon-check hidden" />
										<span class="btn-label">Agregar al carrito</span>
									</button>
								</div>
							</div>
						</div>
					);
				})
			}
		</div>

		<div
			id="no-results"
			class="hidden py-16 text-center text-muted-strong text-sm"
		>
			Sin resultados. Intenta con "pixel 8", "pantalla" o "batería".
		</div>
	</main>

	<style>
		.chip-active {
			background: var(--color-ink);
			color: var(--color-surface);
			border-color: var(--color-ink);
			font-weight: 500;
		}
		.chip-inactive {
			background: transparent;
			color: var(--color-muted-strong);
			border-color: var(--color-border-strong);
			font-weight: 400;
		}
		.chip-inactive:hover {
			border-color: var(--color-ink);
			color: var(--color-ink);
			background: var(--color-surface-muted);
		}
	</style>

	<script>
		let activeType = "all",
			activeSeries = "all",
			activeModel = "all",
			query = "";

		function updateModelChipsVisibility() {
			const container = document.getElementById("model-filters-container");
			if (!container) return;

			// Si no hay serie activa, escondemos todo el bloque de modelos
			if (activeSeries === "all") {
				container.classList.add("hidden");
				activeModel = "all";
				const allModelBtn = document.querySelector(
					'.model-btn[data-model="all"]',
				);
				if (allModelBtn) activateChip("model-btn", allModelBtn);
				return;
			}

			// Si hay serie seleccionada, mostramos el contenedor
			container.classList.remove("hidden");

			const modelButtons = document.querySelectorAll(".model-btn");
			modelButtons.forEach((btn) => {
				const el = btn as HTMLElement;
				if (el.dataset.model === "all") return;

				if (el.dataset.parentSeries !== activeSeries) {
					el.style.display = "none";
					if (activeModel === el.dataset.model) {
						activeModel = "all";
						const allModelBtn = document.querySelector(
							'.model-btn[data-model="all"]',
						);
						if (allModelBtn) activateChip("model-btn", allModelBtn);
					}
				} else {
					el.style.display = "";
				}
			});
		}

		function applyFilter() {
			updateModelChipsVisibility();

			const cards = document.querySelectorAll(".catalog-card");
			let visible = 0;

			cards.forEach((card) => {
				const el = card as HTMLElement;
				const matchType =
					activeType === "all" || el.dataset.type === activeType;
				const matchSeries =
					activeSeries === "all" || el.dataset.series === activeSeries;
				const matchModel =
					activeModel === "all" || el.dataset.model === activeModel;

				const words = query.toLowerCase().split(/\s+/).filter(Boolean);
				const matchQuery =
					!words.length ||
					words.every((w) => (el.dataset.text || "").includes(w));

				const show = matchType && matchSeries && matchModel && matchQuery;
				el.style.display = show ? "" : "none";
				if (show) visible++;
			});

			const countEl = document.getElementById("results-count");
			if (countEl) {
				const noun = countEl.dataset.noun ?? "producto";
				countEl.textContent = `${visible} ${noun}${visible !== 1 ? "s" : ""} disponible${visible !== 1 ? "s" : ""}`;
			}

			document
				.getElementById("no-results")!
				.classList.toggle("hidden", visible > 0);
			document
				.getElementById("catalog-grid")!
				.classList.toggle("hidden", visible === 0);
		}

		function activateChip(cls: string, selected: Element) {
			document.querySelectorAll(`.${cls}`).forEach((b) => {
				b.className =
					b.className.replace(/chip-\w+/g, "").trim() +
					(b === selected ? " chip-active" : " chip-inactive");
			});
		}

		document.getElementById("type-filters")?.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".type-btn") as HTMLElement;
			if (!btn) return;
			activeType = btn.dataset.type!;
			activateChip("type-btn", btn);
			applyFilter();
		});

		document
			.getElementById("series-filters")!
			.addEventListener("click", (e) => {
				const btn = (e.target as Element).closest(".series-btn") as HTMLElement;
				if (!btn) return;
				activeSeries = btn.dataset.series!;
				activateChip("series-btn", btn);
				applyFilter();
			});

		document.getElementById("model-filters")!.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".model-btn") as HTMLElement;
			if (!btn) return;
			activeModel = btn.dataset.model!;
			activateChip("model-btn", btn);
			applyFilter();
		});

		document.getElementById("search-input")!.addEventListener("input", (e) => {
			query = (e.target as HTMLInputElement).value;
			applyFilter();
		});

		document.getElementById("catalog-grid")!.addEventListener("click", (e) => {
			const btn = (e.target as Element).closest(".add-btn") as HTMLElement;
			if (!btn || !window.pfCart) return;
			window.pfCart.add(
				btn.dataset.id!,
				btn.dataset.name!,
				btn.dataset.part!,
				Number(btn.dataset.price),
			);
		});
	</script>
</div>
