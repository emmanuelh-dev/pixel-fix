---
interface Props {
	title?: string;
	description?: string;
	items: { question: string; answer: string }[];
}

const { title = "Dudas Frecuentes.", description, items } = Astro.props;
---

<section id="faq" class="max-w-3xl mx-auto px-6 py-24 border-t border-border reveal">
	<div class="mb-12">
		<h2 class="text-3xl tracking-tight text-ink mb-4">{title}</h2>
		{description && <p class="text-muted leading-[1.6]">{description}</p>}
	</div>

	<div class="space-y-6">
		{
			items.map((faq) => (
				<div class="pb-6 border-b border-border">
					<h3 class="text-lg font-medium text-ink mb-3">{faq.question}</h3>
					<p class="text-muted text-sm leading-[1.6]">{faq.answer}</p>
				</div>
			))
		}
	</div>
</section>
